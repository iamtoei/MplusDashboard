    /* ==================== OVERVIEW VIEW ==================== */
    function renderOverview() {
        const all = getContracts();
        const ranged = filterByRange(all, _currentRange);
        const active = all.filter(c => c.status !== 'returned' && c.status !== 'paidoff');
        renderKPIs(all, ranged, active);
        renderBranchChart(all);
