        body.innerHTML = sorted.map((c,i) => {
            const name = c.customerName || '-';
            const initial = (name.charAt(0) || '?').toUpperCase();
            const total = (Number(c.totalPrice)||0);
            const remain = Math.max(0, total - (Number(c.downPayment)||0) - (Number(c.paidTotal)||0));
            const t = typeMap[c.type] || [c.type || '—', 'gray'];
            const g = c.gradeColor || 'none';
            const status = c.status === 'paidoff' ? ['ปิดยอดแล้ว','gray']
                          : c.status === 'returned' ? ['คืนเครื่อง','red']
                          : c.isDeferred ? ['เลื่อนนัด','yellow']
                          : daysOverdue(c) > 0 ? [`ค้าง ${daysOverdue(c)}ว.`, daysOverdue(c) > 7 ? 'red' : 'yellow']
                          : ['ปกติ','green'];
            return `<tr><td><div class="dov-cust"><div class="dov-cust-avatar" style="background:${palette[i%palette.length]}">${initial}</div><div class="dov-cust-info"><div class="dov-cust-name">${name}</div><div class="dov-cust-id">${(c.productName||'').slice(0,28) || '—'}</div></div></div></td><td style="color:#475569;">${c.branchId || '—'}</td><td><span class="dov-pill ${t[1]}"><span class="dot"></span>${t[0]}</span></td><td><div style="font-weight:700;color:#0F172A;">${fmt(total)}</div><div style="font-size:11px;color:#64748B;">เหลือ ${fmt(remain)}</div></td><td>${g==='none' ? '<span style="color:#94A3B8;font-size:12px;">—</span>' : `<span style="display:inline-flex;align-items:center;gap:5px;font-size:12px;color:${gradeColor[g]};font-weight:600;"><span style="width:8px;height:8px;border-radius:50%;background:${gradeColor[g]};"></span>${gradeLbl[g]||g}</span>`}</td><td><span class="dov-pill ${status[1]}"><span class="dot"></span>${status[0]}</span></td></tr>`;
