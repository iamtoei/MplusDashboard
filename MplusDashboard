        window.deleteLogByMatch = async (contractId, amount, type, timestamp, customerName) => {
            if (!confirm('ยืนยันลบประวัติ ' + (type === 'fine' ? 'ค่าบริการ' : 'ค่างวด') + ' ' + Number(amount).toLocaleString() + ' ฿ ของ ' + customerName + '?')) return;
            try {
                // GAS: ค้นหา log จาก cache แล้วลบด้วย deletePaymentLog
                const logToDelete = cachedLogs.find(l =>
                    l.contractId === contractId &&
                    Number(l.amount) === Number(amount) &&
                    l.type === type &&
                    (l.timestamp === timestamp || !timestamp)
                );
                if (!logToDelete || !logToDelete.id) { alert('ไม่พบ log นี้ กรุณา refresh แล้วลองใหม่'); return; }
                await _gs('deletePaymentLog', logToDelete.id);
                cachedLogs = cachedLogs.filter(l => l.id !== logToDelete.id);
                if (window._logsIndex?.[contractId]) {
                    window._logsIndex[contractId] = window._logsIndex[contractId].filter(l => l.id !== logToDelete.id);
                }
                const contract = cachedContracts.find(c => c.id === contractId);
                if (contract && type !== 'fine') {
                    const newPaid = Math.max(0, (Number(contract.paidTotal)||0) - Number(amount));
                    await _gs('updateContractFields', contractId, { paidTotal: newPaid });
                    cachedContracts = cachedContracts.map(c => c.id === contractId ? { ...c, paidTotal: newPaid } : c);
                }
                renderAll();
                renderHistoryModal(contractId, customerName);
                showTrackingToast('ลบประวัติแล้ว', customerName);
            } catch(e) { alert('เกิดข้อผิดพลาด: ' + e.message); }
        };
    window.deleteLog = async (logId, amount, contractId, customerName) => {
        if (!confirm(`ลบประวัติการชำระ ${Number(amount).toLocaleString()} ฿ ?\n\nระบบจะหักยอดชำระออกอัตโนมัติ`)) return;
        try {
            const deletedLog = cachedLogs.find(l => l.id === logId);
            await deleteDoc(doc(db, "payment_logs", logId));
            if (deletedLog && deletedLog.type !== 'fine') {
                const contract = cachedContracts.find(c => c.id === contractId);
                if (contract) {
                    const newPaidTotal = Math.max(0, (Number(contract.paidTotal) || 0) - Number(amount));
                    // FIX: คำนวณวันนัดชำระใหม่ตาม paidTotal ที่ถูกต้องหลังลบ log (แก้ปัญหายอดผิดเพี้ยนใน แก้ด่วน)
                    const mPayDel = Number(contract.monthlyPay) || 1;
                    const paidInstDel = Math.floor(newPaidTotal / mPayDel);
                    const contractDateDel = contract.contractDate ? new Date(contract.contractDate) : new Date();
                    const dueDayDel = contract.dueDay || (contract.currentDueDate ? new Date(contract.currentDueDate).getDate() : contractDateDel.getDate());
                    const newDueDel = new Date(contractDateDel.getFullYear(), contractDateDel.getMonth() + paidInstDel + 1, 1);
                    const maxDayDel = new Date(newDueDel.getFullYear(), newDueDel.getMonth() + 1, 0).getDate();
                    newDueDel.setDate(Math.min(dueDayDel, maxDayDel));
                    newDueDel.setHours(12, 0, 0, 0);
                    const newDueDateDel = newDueDel.toISOString();
                    await updateDoc(doc(db, "contracts", contractId), { paidTotal: newPaidTotal, currentDueDate: newDueDateDel });
                    cachedContracts = cachedContracts.map(c => c.id === contractId ? { ...c, paidTotal: newPaidTotal, currentDueDate: newDueDateDel } : c);
                }
            } else if (deletedLog && deletedLog.type === 'fine') {
                const contract = cachedContracts.find(c => c.id === contractId);
                if (contract) {
                    const newFinePaid = Math.max(0, (Number(contract.totalFinePaid) || 0) - Number(amount));
                    await updateDoc(doc(db, "contracts", contractId), { totalFinePaid: newFinePaid });
                    cachedContracts = cachedContracts.map(c => c.id === contractId ? { ...c, totalFinePaid: newFinePaid } : c);
                }
            }
            cachedLogs = cachedLogs.filter(l => l.id !== logId);
            renderHistoryModal(contractId, customerName);
            renderAll();
        } catch(e) { alert('ลบไม่สำเร็จ: ' + e.message); }
    };
