    function getMonthData(ym) {
        // Income, Cost from contracts ที่ contractDate อยู่ในเดือนนั้น (filter ด้วยสาขาด้วย)
        const all = getContracts().filter(c => !_plBranch || c.branchId === _plBranch);
        const inMonth = all.filter(c => ymOf(c.contractDate || c.createdAt || c.date) === ym);
        let income = 0, cost = 0;
        inMonth.forEach(c => {
            income += (Number(c.downPayment)||0) + (Number(c.paidTotal)||0);
            cost += (Number(c.costPrice)||0);
        });
        const exps = _expenses.filter(e => ymOf(e.date) === ym && (!_plBranch || (e.branchId||'') === _plBranch));
        const expense = exps.reduce((s,e) => s + (Number(e.amount)||0), 0);
        return { income, cost, expense, exps, contractsInMonth: inMonth, all };
    }

