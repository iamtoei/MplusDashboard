    // ── กำหนด threshold "กำไร (black)" ตามจำนวนงวดรวมของสัญญา ──────────────
    function getBlackThreshold(totalInstallments) {
        const n = Number(totalInstallments) || 0;
        if (n >= 36) return 30;
        if (n >= 24) return 20;
        if (n >= 18) return 14;
        if (n >= 15) return 10;
        if (n >= 12) return 9;
        return 9; // default
    }
    // Normalize ชื่อรุ่น: รวมชื่อย่อ/สลับรูปแบบให้เป็นชื่อมาตรฐาน
    function normalizeModel(name) {
        if (!name || !name.trim()) return 'ไม่ระบุรุ่น';
        let s = name.trim();
        // 1) ตัด GB/TB และทุกอย่างหลัง
        s = s.replace(/\s*\d+\s*(?:GB|TB).*/i, '').trim();
        // 2) ตัด /xxx ทุกอย่างหลัง slash เช่น /128/G/TH, /N, /W, /B
        s = s.replace(/\s*\/.*$/, '').trim();
        // 3) ตัดวงเล็บ (New), (Used) ฯลฯ
        s = s.replace(/\s*\(.*?\)/g, '').trim();
        // 4) ตัดตัวเลขขนาดความจุที่อยู่โดดๆ (32/64/128/256/512)
        s = s.replace(/\b(32|64|128|256|512)\b/g, '').replace(/\s+/g, ' ').trim();
        // 5) ตัดคำสภาพท้าย
        s = s.replace(/\s+(มือสอง|มือ\s*[12]|new|newAcc|nobox|เก่า|acc|refurb|used)\s*$/i, '').trim();
        // 6) แปลงชื่อย่อ → ชื่อเต็ม (iP / PM / ตัวเลขล้วน)
        s = s.replace(/^ip(\d+)\s*(pro\s*max|pm)\b/i, 'iPhone $1 Pro Max');
        s = s.replace(/^ip(\d+)\s*pro\b/i,            'iPhone $1 Pro');
        s = s.replace(/^ip(\d+)\b/i,                  'iPhone $1');
        s = s.replace(/^(\d+)\s*(pro\s*max|pm)\b/i,   'iPhone $1 Pro Max');
        s = s.replace(/^(\d+)\s*pro\b/i,              'iPhone $1 Pro');
        s = s.replace(/^(\d{2})\s*$/,                 'iPhone $1');
        return s || name.trim();
    }
    // เรียงรุ่นล่าสุดก่อน: ตัวเลขซีรีส์สูง > Pro Max > Pro > Plus > base
    function modelSortKey(modelName) {
        const n = (modelName.match(/(\d+)/) || [0,0])[1];
        const num = parseInt(n) || 0;
        const v = modelName.includes('Pro Max') ? 4 : modelName.includes('Pro') ? 3 : modelName.includes('Plus') ? 2 : modelName.includes('Ultra') ? 5 : 1;
        return num * 10 + v;
    }
