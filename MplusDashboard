  function mkRenderCrosstab(data,rowKey,colKey,tableId,colOrder){
    const rows={};const cols=new Set();
    data.forEach(r=>{const row=r[rowKey]||'ไม่ระบุ';const col=r[colKey]||'ไม่ระบุ';rows[row]=rows[row]||{};rows[row][col]=(rows[row][col]||0)+1;cols.add(col);});
    const colList=colOrder?colOrder.filter(c=>cols.has(c)):Array.from(cols).sort();
    const rowList=Object.keys(rows).sort((a,b)=>{const sa=Object.values(rows[a]).reduce((x,y)=>x+y,0);const sb=Object.values(rows[b]).reduce((x,y)=>x+y,0);return sb-sa;});
    let maxV=0;
    rowList.forEach(r=>colList.forEach(c=>{maxV=Math.max(maxV,rows[r][c]||0);}));
    let html='<thead><tr><th>'+rowKey+'</th>';
    colList.forEach(c=>html+='<th class="mk-num">'+c+'</th>');
    html+='<th class="mk-num">รวม</th></tr></thead><tbody>';
    rowList.forEach(r=>{let total=0;html+='<tr><td><b>'+r+'</b></td>';colList.forEach(c=>{const v=rows[r][c]||0;total+=v;const ratio=maxV>0?v/maxV:0;const heat=ratio>.75?'mk-heat-4':ratio>.5?'mk-heat-3':ratio>.25?'mk-heat-2':ratio>0?'mk-heat-1':'';html+='<td class="mk-num '+heat+'">'+(v||'-')+'</td>';});html+='<td class="mk-num"><b>'+total+'</b></td></tr>';});
    html+='</tbody>';
    document.getElementById(tableId).innerHTML=html;
  }

