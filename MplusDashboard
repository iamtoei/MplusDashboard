                <div style="display:flex; align-items:center; gap:10px;">
                    <span style="font-size:15px; font-weight:600; color:${isFine ? 'var(--danger)' : 'var(--success)'};">${amt.toLocaleString()} ฿</span>
                    ${hasId
                        ? `<button class="btn-del-paylog" data-mode="byid" data-log-id="${(log.id+'').replace(/"/g,'&quot;')}" data-amount="${amt}" data-contract-id="${(id+'').replace(/"/g,'&quot;')}" data-customer="${(customerName+'').replace(/"/g,'&quot;').replace(/</g,'&lt;')}" style="background:#FEE2E2; color:#B91C1C; border:none; border-radius:8px; padding:5px 10px; cursor:pointer; font-family:'Kanit'; font-size:11px; font-weight:600;">ลบ</button>`
                        : `<button class="btn-del-paylog" data-mode="bymatch" data-contract-id="${(id+'').replace(/"/g,'&quot;')}" data-amount="${amt}" data-type="${(log.type||'installment').replace(/"/g,'&quot;')}" data-timestamp="${(log.timestamp||'').replace(/"/g,'&quot;')}" data-customer="${(customerName+'').replace(/"/g,'&quot;').replace(/</g,'&lt;')}" style="background:#FEE2E2; color:#B91C1C; border:none; border-radius:8px; padding:5px 10px; cursor:pointer; font-family:'Kanit'; font-size:11px; font-weight:600;">ลบ</button>`
                    }
                </div>
            </div>`;
        }).join('');
        document.getElementById("historyList").innerHTML = summaryHtml + rowsHtml;
    }
    // ========== รีไฟแนนซ์ (Feature 2) ==========
