            if (DEFAULT_TYPES.find(d => d.key === key) || window._customTypes.find(d => d.key === key)) return alert('key นี้มีอยู่แล้ว กรุณาเปลี่ยน');
            try {
                await addDoc(collection(db, 'contract_types'), { key, label, createdAt: new Date().toISOString() });
                document.getElementById('newTypeName').value = '';
                document.getElementById('newTypeKey').value = '';
                await window.loadCustomTypes();
                window.renderCustomTypesList();
                showTrackingToast('เพิ่มกลุ่มสำเร็จ', label);
            } catch(e) { alert('เกิดข้อผิดพลาด: ' + e.message); }
        };

        window.deleteCustomType = async (docId, key) => {
            if (!confirm('ลบกลุ่ม "' + key + '" ออก? สัญญาที่ใช้กลุ่มนี้อยู่จะยังคงข้อมูลไว้')) return;
            try {
                await deleteDoc(doc(db, 'contract_types', docId));
                await window.loadCustomTypes();
                window.renderCustomTypesList();
                showTrackingToast('ลบกลุ่มแล้ว', key);
