                if (typeof showTrackingToast === 'function') {
                    showTrackingToast(value ? 'แยกออกแล้ว' : 'รวมกลับเข้าระบบ', value ? 'ไม่โผล่ในแท็บติดตาม/เกรด/KPI' : 'กลับมาในระบบติดตามปกติ');
