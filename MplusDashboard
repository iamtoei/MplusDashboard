    delete age['ไม่ระบุ'];delete occ['ไม่ระบุ'];
    const sortedCh=Object.entries(ch).sort((a,b)=>b[1]-a[1]);
    if(sortedCh.length){const [top,n]=sortedCh[0];const p=mkPct(n,total);ins.push('<b>'+top+'</b> เป็นช่องทางอันดับ 1 ได้ลูกค้า '+n+' ราย ('+p+'%) — '+(p>50?'พึ่งพาช่องทางนี้สูงมาก ควรกระจายความเสี่ยงไปช่องทางอื่น':'ยังควรเพิ่มงบโฆษณาในช่องทางนี้'));}
    if(sortedCh.length>=2&&sortedCh[1][1]<sortedCh[0][1]/3){ins.push('ช่องทาง <b>'+sortedCh[1][0]+'</b> เป็นที่ 2 แต่ห่างจากที่ 1 มาก ('+sortedCh[1][1]+' vs '+sortedCh[0][1]+') — ทดลองเพิ่ม campaign ในช่องทางนี้');}
    const sortedAge=Object.entries(age).sort((a,b)=>b[1]-a[1]);
    if(sortedAge.length){const [a,n]=sortedAge[0];ins.push('กลุ่มเป้าหมายหลักคือ <b>'+a+'</b> ('+n+' ราย / '+mkPct(n,total)+'%) — ทำ content / โปรโมชั่นที่ตรงกับกลุ่มนี้');}
    const sortedOcc=Object.entries(occ).sort((a,b)=>b[1]-a[1]);
    if(sortedOcc.length){const [o,n]=sortedOcc[0];ins.push('<b>'+o+'</b> เป็นกลุ่มอาชีพหลัก ('+n+' ราย / '+mkPct(n,total)+'%) — ออกแบบแผนการผ่อนชำระให้สอดคล้อง');}
    const chRev=mkSumBy(data,'channel',mkRevenue);
    const sortedRev=Object.entries(chRev).sort((a,b)=>b[1]-a[1]);
    if(sortedRev.length){const [r,rev]=sortedRev[0];const cust=ch[r]||1;ins.push('<b>'+r+'</b> สร้างรายได้ '+mkFmt(rev)+' เฉลี่ย '+mkFmt(rev/cust)+'/ลูกค้า');}
    const cash=data.filter(r=>r.saleType==='ขายสด').length;
    const inst=data.filter(r=>r.saleType==='ขายผ่อน').length;
    if(cash+inst>0){ins.push('สัดส่วน <b>ขายผ่อน:ขายสด</b> = '+mkPct(inst,cash+inst)+'% : '+mkPct(cash,cash+inst)+'% — '+(mkPct(inst,cash+inst)>50?'ลูกค้านิยมผ่อน → เน้นโปรแกรมผ่อนดึงดูด':'ลูกค้านิยมจ่ายสด → push promotion cash'));}
    document.getElementById('mkInsightsList').innerHTML=ins.map(i=>'<li>'+i+'</li>').join('');
  }

  function mkRefresh(){
    if(typeof Chart==='undefined'){console.warn('[Marketing] Chart.js not loaded');return;}
    if(!document.getElementById('mkKpiTotal')) return; // tab not in DOM
    Chart.defaults.font.family="'Kanit',sans-serif";
    Chart.defaults.color='#475569';
    const data=mkGetData();
    mkRenderKPIs(data);
    mkRenderChannelChart(data);
    mkRenderChannelRev(data);
    mkRenderAge(data);
    mkRenderOcc(data);
    mkRenderBranch(data);
    const ageOrder=['18-25 ปี','26-35 ปี','36-45 ปี','45 ปีขึ้นไป','ไม่ระบุ'];
    mkRenderCrosstab(data,'channel','age','mkCrossChannelAge',ageOrder);
    mkRenderCrosstab(data,'channel','occupation','mkCrossChannelOcc');
    mkGenerateInsights(data);
    // NEW: หนี้เสีย × อาชีพ (live data จาก Firestore)
    mkRenderBadDebtByOccupation();
  }

  // หนี้เสีย × อาชีพ — ดึงจาก window._getContracts() (cachedContracts)
  function mkRenderBadDebtByOccupation(){
    mkDestroy('badDebt');
    const wrap = document.getElementById('mkBadDebtChartWrap');
    const empty = document.getElementById('mkBadDebtEmpty');
    const sumEl = document.getElementById('mkBadDebtSummary');
    if (!wrap || !empty) return;
    const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : (window.allContracts||[]));
    const today = new Date(); today.setHours(0,0,0,0);
    // เลือกเฉพาะลูกค้าที่หนี้เสีย: autoGrade === 'gray' หรือ dd >= 365 + ยังมียอดค้าง
    const badDebts = contracts.filter(c => {
      if (c.status === 'returned' || c.status === 'paidoff') return false;
      const paid = Number(c.paidTotal)||0;
      const total = Number(c.totalPrice)||0;
      const down = Number(c.downPayment)||0;
      const rem = Math.max(0, total - down - paid);
      if (rem <= 0) return false;
      const due = c.currentDueDate ? new Date(c.currentDueDate) : new Date();
      due.setHours(0,0,0,0);
      const dd = Math.floor((today - due) / 86400000);
      return c.autoGrade === 'gray' || dd >= 365;
    });
    const withOcc = badDebts.filter(c => c.occupation && c.occupation.trim());
    // ถ้าไม่มีลูกค้าที่มี occupation field → empty state
    if (withOcc.length === 0) {
      wrap.style.display = 'none';
      empty.style.display = 'block';
      if (sumEl) sumEl.innerHTML = '<b style="color:#DC2626;">' + badDebts.length + '</b> ราย หนี้เสีย · มีข้อมูลอาชีพ ' + withOcc.length + ' ราย';
      return;
    }
    empty.style.display = 'none';
    wrap.style.display = 'block';
    // นับตาม occupation
    const byOcc = {};
    let totalRemain = 0;
    withOcc.forEach(c => {
      const occ = c.occupation.trim();
      const rem = Math.max(0, (Number(c.totalPrice)||0) - (Number(c.downPayment)||0) - (Number(c.paidTotal)||0));
      if (!byOcc[occ]) byOcc[occ] = { count:0, remain:0 };
      byOcc[occ].count++;
      byOcc[occ].remain += rem;
      totalRemain += rem;
    });
    const sorted = Object.entries(byOcc).sort((a,b) => b[1].count - a[1].count);
    const labels = sorted.map(x => x[0]);
    const counts = sorted.map(x => x[1].count);
    const remains = sorted.map(x => x[1].remain);
    // Summary text
    if (sumEl) {
      const top = sorted[0];
      sumEl.innerHTML = '<b style="color:#DC2626;">' + badDebts.length + '</b> ราย หนี้เสีย · มีข้อมูลอาชีพ ' + withOcc.length + ' ราย<br>'
        + '<b>' + top[0] + '</b> = ' + top[1].count + ' ราย · ' + mkFmt(top[1].remain);
    }
    mkCharts.badDebt = new Chart(document.getElementById('mkBadDebtChart'), {
      type:'bar',
      data:{
        labels: labels,
        datasets:[
          { label:'จำนวนคน', data: counts, backgroundColor:'#DC2626', borderRadius:6, barThickness:22, yAxisID:'y' },
          { label:'ยอดค้าง (฿)', data: remains, backgroundColor:'#F59E0B', borderRadius:6, barThickness:22, yAxisID:'y1' }
        ]
      },
      options:{
        indexAxis:'y',
        responsive:true,
        maintainAspectRatio:false,
        plugins:{
          legend:{ position:'top', labels:{ usePointStyle:true, boxWidth:10, padding:10, font:{size:11} } },
          tooltip:{ backgroundColor:'#0F172A', padding:10, cornerRadius:8,
            callbacks:{ label: ctx => ctx.dataset.label === 'ยอดค้าง (฿)' ? mkFmt(ctx.parsed.x) : (ctx.parsed.x + ' ราย') }
          }
        },
        scales:{
          x:{ grid:{color:'#F1F5F9'}, ticks:{ precision:0 } },
          y:{ grid:{display:false}, ticks:{font:{size:11.5}} },
          y1:{ display:false }
        }
      }
    });
  }

  // expose
  window.renderMarketing = mkRefresh;

  // wire up filter buttons (delegation)
  document.addEventListener('click',function(e){
    const btn=e.target.closest('#mkFilter button[data-mkfilter]');
    if(!btn) return;
    document.querySelectorAll('#mkFilter button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    _mkFilter=btn.dataset.mkfilter;
    mkRefresh();
  });
})();
// ========== END MARKETING TAB JS ==========
</script>
<!-- ========== END MARKETING TAB SCRIPT ========== -->

<!-- ========== RECOVERY PAGE SCRIPT (auto-injected) ========== -->
<script>
(function(){
  if (window.RECOVERY_INIT) return; window.RECOVERY_INIT = true;

  function _normProvince(p){ return (p||'ไม่ระบุ').toString().trim() || 'ไม่ระบุ'; }
  function _normZone(z){ return (z||'').toString().trim() || '— ไม่ระบุโซน —'; }
  function _fmt(n){ return Math.round(Number(n)||0).toLocaleString('th-TH'); }
  function _esc(s){ return (s==null?'':String(s)).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

  function _getLatestTrackingFor(contractId){
    const logs = (typeof window._getTracking === 'function' ? window._getTracking() : []);
    return logs
      .filter(t => t.contractId === contractId)
      .sort((a,b) => (b.createdAt||b.date||'').localeCompare(a.createdAt||a.date||''))[0] || null;
  }

  function _getRecoveryContracts(){
    const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : (window.allContracts||[]));
    const today = new Date(); today.setHours(0,0,0,0);
    return contracts.filter(c => {
      if (c.status === 'returned' || c.status === 'paidoff') return false;
      if (c.isDeferred) return false;
      if (c.isRecovered) return false;            // ✅ ได้เครื่องคืน/ย้ายออกแล้ว
      if (c.movedOutOfRecovery) return false;     // ✅ admin ย้ายออก manual
      const paid = Number(c.paidTotal)||0;
      const rem = Math.max(0, (Number(c.totalPrice)||0) - (Number(c.downPayment)||0) - paid);
      if (rem <= 0) return false;
      const due = c.currentDueDate ? new Date(c.currentDueDate) : new Date();
      due.setHours(0,0,0,0);
      const dd = Math.floor((today - due) / 86400000);
      return dd >= 15;
    }).map(c => {
      const paid = Number(c.paidTotal)||0;
      const rem = Math.max(0, (Number(c.totalPrice)||0) - (Number(c.downPayment)||0) - paid);
      const due = c.currentDueDate ? new Date(c.currentDueDate) : new Date();
      due.setHours(0,0,0,0);
      const today2 = new Date(); today2.setHours(0,0,0,0);
      const dd = Math.floor((today2 - due) / 86400000);
      return { ...c, _remain: rem, _overdueDays: dd };
    });
  }

  window.openRecoveryPage = function(){
    const page = document.getElementById('recoveryPage');
    if (!page) return;
    page.classList.add('open');
    document.body.style.overflow = 'hidden';
    // เติม dropdown จังหวัด + โซน
    const rows = _getRecoveryContracts();
    const provinces = [...new Set(rows.map(r => _normProvince(r.province)))].sort();
    const zones = [...new Set(rows.map(r => _normZone(r.zone)))].sort();
    const pSel = document.getElementById('recFilterProvince');
    const zSel = document.getElementById('recFilterZone');
    if (pSel) pSel.innerHTML = '<option value="">ทุกจังหวัด</option>' + provinces.map(p => '<option>'+_esc(p)+'</option>').join('');
    if (zSel) zSel.innerHTML = '<option value="">ทุกโซน</option>' + zones.map(z => '<option>'+_esc(z)+'</option>').join('');
    window.renderRecoveryPage();
  };

  window.closeRecoveryPage = function(){
    const page = document.getElementById('recoveryPage');
    if (page) page.classList.remove('open');
    document.body.style.overflow = '';
  };

  window.renderRecoveryPage = function(){
    const list = document.getElementById('recList');
    const statEl = document.getElementById('recStat');
    if (!list) return;
    const filterP = (document.getElementById('recFilterProvince')||{}).value || '';
    const filterZ = (document.getElementById('recFilterZone')||{}).value || '';
    const search = ((document.getElementById('recFilterSearch')||{}).value || '').toLowerCase().trim();

    let rows = _getRecoveryContracts();
    if (filterP) rows = rows.filter(r => _normProvince(r.province) === filterP);
    if (filterZ) rows = rows.filter(r => _normZone(r.zone) === filterZ);
    if (search) rows = rows.filter(r => (
      (r.customerName||'').toLowerCase().includes(search) ||
      (r.productName||'').toLowerCase().includes(search) ||
      (r.sn||'').toLowerCase().includes(search) ||
      (r.customerPhone||'').toLowerCase().includes(search)
    ));

    const totalRemain = rows.reduce((s, r) => s + r._remain, 0);
    if (statEl) statEl.innerText = rows.length + ' ราย · ยอดค้างรวม ' + _fmt(totalRemain) + ' ฿';

    if (rows.length === 0) {
      list.innerHTML = '<div class="rec-empty"><div class="rec-emp-icon">📭</div>ยังไม่มีลูกค้าที่ต้องตามคืนเครื่อง<br><span style="font-size:12px;">(เกณฑ์: ค้าง ≥ 15 วัน + ยังไม่พักชำระ + ยังไม่คืน)</span></div>';
      return;
    }

    // group: province → zone → contracts
    const grouped = {};
    rows.forEach(r => {
      const p = _normProvince(r.province);
      const z = _normZone(r.zone);
      if (!grouped[p]) grouped[p] = {};
      if (!grouped[p][z]) grouped[p][z] = [];
      grouped[p][z].push(r);
    });

    const provinceOrder = Object.keys(grouped).sort((a,b) => {
      const ca = Object.values(grouped[a]).reduce((s, arr) => s + arr.length, 0);
      const cb = Object.values(grouped[b]).reduce((s, arr) => s + arr.length, 0);
      return cb - ca;
    });

    let html = '';
    provinceOrder.forEach(p => {
      const zones = grouped[p];
      const pCount = Object.values(zones).reduce((s, arr) => s + arr.length, 0);
      const pRemain = Object.values(zones).flat().reduce((s, c) => s + c._remain, 0);
      html += '<div class="rec-group">';
      html += '<div class="rec-group-h">📍 ' + _esc(p) + ' <span class="badge">' + pCount + ' ราย</span><span class="badge-amt">' + _fmt(pRemain) + ' ฿</span></div>';

      const zoneOrder = Object.keys(zones).sort((a,b) => zones[b].length - zones[a].length);
      zoneOrder.forEach(z => {
        const items = zones[z];
        html += '<div class="rec-subgroup">';
        html += '<div class="rec-subgroup-h">📌 โซน: ' + _esc(z) + ' (' + items.length + ' ราย)</div>';
        items.sort((a,b) => b._overdueDays - a._overdueDays);
        items.forEach(c => {
          const mapLink = c.deviceMapLink || '';
          const note = c.recoveryNote || '';
          html += '<div class="rec-card" data-id="' + _esc(c.id) + '">';
          html += '<div class="rec-card-top">';
          html += '<div><div class="rec-cust">' + _esc(c.customerName||'-') + (c.customerPhone ? ' · 📞 ' + _esc(c.customerPhone) : '') + '</div>';
          html += '<div class="rec-prod">' + _esc(c.productName||'-') + (c.sn ? ' · SN: ' + _esc(c.sn) : '') + '</div></div>';
          html += '<div style="text-align:right;"><div class="rec-debt">' + _fmt(c._remain) + ' ฿</div>';
          html += '<div class="rec-overdue">ค้าง ' + c._overdueDays + ' วัน</div></div>';
          html += '</div>';
          html += '<div class="rec-fields">';
          html += '<div class="full"><label>🗺️ Google Maps Link (พิกัดอุปกรณ์)</label><input type="url" placeholder="https://maps.google.com/..." value="' + _esc(mapLink) + '" data-fld="deviceMapLink"></div>';
          html += '<div><label>จังหวัด</label><input type="text" placeholder="เช่น เชียงใหม่" value="' + _esc(c.province||'') + '" data-fld="province"></div>';
          html += '<div><label>โซน / อำเภอ</label><input type="text" placeholder="เช่น เมือง" value="' + _esc(c.zone||'') + '" data-fld="zone"></div>';
          html += '<div><label>โทรศัพท์</label><input type="tel" placeholder="" value="' + _esc(c.customerPhone||'') + '" data-fld="customerPhone"></div>';
          html += '<div class="full"><label>📝 หมายเหตุ (รถอะไร / เส้นทาง / ที่จอด ฯลฯ)</label><textarea data-fld="recoveryNote" placeholder="...">' + _esc(note) + '</textarea></div>';
          html += '</div>';
          // ประวัติติดตามล่าสุด (ถ้ามี)
          const lastTrack = _getLatestTrackingFor(c.id);
          if (lastTrack) {
            const resColors = { got_device:'#22C55E', paid:'#1E3A8A', not_found:'#64748B', follow_again:'#8B5CF6' };
            const col = resColors[lastTrack.result] || '#94A3B8';
            html += '<div style="margin-top:10px;padding:8px 12px;background:' + col + '15;border-left:3px solid ' + col + ';border-radius:6px;font-size:12px;color:#334155;">'
                  + '<b style="color:' + col + ';">ผลล่าสุด:</b> ' + _esc(lastTrack.resultLabel || lastTrack.result)
                  + ' <span style="color:#94A3B8;">·</span> ' + _esc(lastTrack.date || '')
                  + (lastTrack.note ? ' <span style="color:#94A3B8;">·</span> ' + _esc(lastTrack.note) : '')
                  + '</div>';
          }
          // Result buttons (ติดตามผล) — บันทึกลง tracking_logs + ถ้าได้เครื่อง → ย้ายออกอัตโนมัติ
          html += '<div style="margin-top:10px;padding-top:10px;border-top:1px dashed #E2E8F0;">';
          html += '<div style="font-size:11px;color:#64748B;font-weight:600;margin-bottom:6px;">📋 บันทึกผลการติดตาม:</div>';
          html += '<div style="display:flex;gap:6px;flex-wrap:wrap;">';
          html += '<button class="rec-btn" style="background:#DCFCE7;color:#15803D;" onclick="window.recordRecoveryResult(this,\'' + _esc(c.id) + '\',\'got_device\')">✅ ได้เครื่อง</button>';
          html += '<button class="rec-btn" style="background:#DBEAFE;color:#1E40AF;" onclick="window.recordRecoveryResult(this,\'' + _esc(c.id) + '\',\'paid\')">💰 จ่ายแล้ว</button>';
          html += '<button class="rec-btn" style="background:#F1F5F9;color:#475569;" onclick="window.recordRecoveryResult(this,\'' + _esc(c.id) + '\',\'not_found\')">❌ ไม่เจอตัว</button>';
          html += '<button class="rec-btn" style="background:#EDE9FE;color:#7C3AED;" onclick="window.recordRecoveryResult(this,\'' + _esc(c.id) + '\',\'follow_again\')">🔄 ติดตามอีกครั้ง</button>';
          html += '</div></div>';

          html += '<div class="rec-actions" style="margin-top:10px;">';
          html += '<button class="rec-btn rec-btn-map" ' + (mapLink ? '' : 'disabled') + ' onclick="window.openMapLink(this)">📍 เปิดแผนที่</button>';
          html += '<button class="rec-btn rec-btn-call" onclick="window.recCall(this)">📞 โทร</button>';
          html += '<button class="rec-btn rec-btn-save" onclick="window.saveRecoveryCard(this,\'' + _esc(c.id) + '\')">💾 บันทึก</button>';
          html += '<button class="rec-btn" style="background:#FEE2E2;color:#B91C1C;margin-left:auto;" onclick="window.moveOutOfRecovery(this,\'' + _esc(c.id) + '\')">📤 ย้ายออก</button>';
          html += '</div>';
          html += '</div>';
        });
        html += '</div>';
      });
      html += '</div>';
    });
    list.innerHTML = html;
  };

  window.openMapLink = function(btn){
    const card = btn.closest('.rec-card');
    if (!card) return;
    const inp = card.querySelector('input[data-fld="deviceMapLink"]');
    const url = inp ? inp.value.trim() : '';
    if (!url) return alert('ยังไม่มี Google Maps link ค่ะ');
    window.open(url, '_blank');
  };

  window.recCall = function(btn){
    const card = btn.closest('.rec-card');
    if (!card) return;
    const inp = card.querySelector('input[data-fld="customerPhone"]');
    const phone = inp ? inp.value.trim().replace(/[^\d+]/g,'') : '';
    if (!phone) return alert('ไม่มีเบอร์โทรศัพท์ค่ะ');
    window.location.href = 'tel:' + phone;
  };

  window.saveRecoveryCard = async function(btn, contractId){
    const card = btn.closest('.rec-card');
    if (!card) return;
    const fields = card.querySelectorAll('[data-fld]');
    const updateData = {};
    fields.forEach(f => { updateData[f.dataset.fld] = f.value.trim(); });

    const origText = btn.innerText;
    btn.disabled = true; btn.innerText = '⏳ กำลังบันทึก...';
    try {
      const fb = window._fb;
      if (!fb || !fb.db || !fb.updateDoc || !fb.doc) throw new Error('Firebase API ยังไม่พร้อม');
      await fb.updateDoc(fb.doc(fb.db, 'contracts', contractId), updateData);
      // อัปเดต cache
      const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : null);
      if (contracts) {
        const idx = contracts.findIndex(c => c.id === contractId);
        if (idx >= 0) Object.assign(contracts[idx], updateData);
      }
      if (window.allContracts) {
        const idx2 = window.allContracts.findIndex(c => c.id === contractId);
        if (idx2 >= 0) Object.assign(window.allContracts[idx2], updateData);
      }
      btn.innerText = '✅ บันทึกแล้ว';
      btn.style.background = '#15803D';
      // เปิดปุ่มแผนที่ถ้ามี link
      const mapBtn = card.querySelector('.rec-btn-map');
      if (mapBtn) {
        if (updateData.deviceMapLink) mapBtn.removeAttribute('disabled');
        else mapBtn.setAttribute('disabled', 'true');
      }
      setTimeout(() => { btn.innerText = origText; btn.style.background = ''; btn.disabled = false; }, 1800);
    } catch(e) {
      console.error('[saveRecoveryCard]', e);
      alert('เกิดข้อผิดพลาด: ' + e.message);
      btn.innerText = origText; btn.disabled = false;
    }
  };

  // บันทึกผลติดตาม → เข้า tracking_logs (จะโผล่ในแท็บ "สรุปผลติดตาม")
  // ถ้า got_device → mark contract isRecovered + ย้ายออกอัตโนมัติ
  window.recordRecoveryResult = async function(btn, contractId, result){
    const card = btn.closest('.rec-card');
    if (!card) return;
    const resultLabels = { got_device:'ได้เครื่อง', paid:'จ่ายเงิน', not_found:'ไม่เจอตัว', follow_again:'ออกติดตามอีกครั้ง' };
    const label = resultLabels[result] || result;

    const noteEl = card.querySelector('textarea[data-fld="recoveryNote"]');
    const provEl = card.querySelector('input[data-fld="province"]');
    const zoneEl = card.querySelector('input[data-fld="zone"]');
    const note = noteEl ? noteEl.value.trim() : '';
    const location = [provEl?provEl.value.trim():'', zoneEl?zoneEl.value.trim():''].filter(Boolean).join(' / ') || '-';

    const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : (window.allContracts||[]));
    const c = contracts.find(x => x.id === contractId);
    if (!c) return alert('ไม่พบสัญญา');

    const origText = btn.innerText;
    btn.disabled = true; btn.innerText = '⏳';
    try {
      const fb = window._fb;
      if (!fb || !fb.db || !fb.addDoc || !fb.collection) throw new Error('Firebase API ยังไม่พร้อม');
      const today = new Date().toISOString().split('T')[0];
      const payload = {
        contractId, customerName: c.customerName, productName: c.productName,
        result, resultLabel: label,
        location, note: note || '',
        date: today, createdAt: new Date().toISOString(), source: 'recovery_page'
      };
      const ref = await fb.addDoc(fb.collection(fb.db, 'tracking_logs'), payload);
      // เก็บ id เข้า cache
      if (typeof window._pushTracking === 'function') window._pushTracking({ id: ref.id, ...payload });

      // ถ้าได้เครื่อง → mark isRecovered + ล้างเกรด → ย้ายออกจาก recovery
      if (result === 'got_device') {
        try {
          await fb.updateDoc(fb.doc(fb.db, 'contracts', contractId), { isRecovered: true, gradeColor: null });
          // sync cache
          const idx = contracts.findIndex(x => x.id === contractId);
          if (idx >= 0) Object.assign(contracts[idx], { isRecovered: true, gradeColor: null });
          if (window.allContracts) {
            const i2 = window.allContracts.findIndex(x => x.id === contractId);
            if (i2 >= 0) Object.assign(window.allContracts[i2], { isRecovered: true, gradeColor: null });
          }
        } catch(e2) { console.warn('[recovery] mark isRecovered err:', e2); }
      }

      btn.innerText = '✅ บันทึก';
      btn.style.background = '#16A34A';
      btn.style.color = '#fff';
      // toast
      const t = document.createElement('div');
      t.innerHTML = '<b style="color:white;">บันทึกผลแล้ว</b><br><span style="font-size:11.5px;color:rgba(255,255,255,.85);">' + (c.customerName||'') + ' · ' + label + '</span>';
      t.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1A1F2C;padding:14px 22px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.3);z-index:99999;border-left:4px solid #8B5CF6;font-family:Kanit;color:white;font-size:13px;';
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 2500);

      // ถ้า got_device หรือ paid → ลบการ์ดออกจากหน้าเลย + re-render
      if (result === 'got_device') {
        setTimeout(() => window.renderRecoveryPage(), 700);
      } else {
        // re-render เพื่อโชว์ "ผลล่าสุด" badge
        setTimeout(() => window.renderRecoveryPage(), 700);
      }
    } catch(e) {
      console.error('[recordRecoveryResult]', e);
      alert('บันทึกไม่สำเร็จ: ' + e.message);
      btn.innerText = origText; btn.disabled = false;
    }
  };

  // ย้ายออกจาก list — set movedOutOfRecovery=true (ไม่กระทบ isRecovered/grading)
  window.moveOutOfRecovery = async function(btn, contractId){
    if (!confirm('ย้ายลูกค้าคนนี้ออกจากรายการตามคืนเครื่อง?\n(จะกลับมาแสดงไม่ได้ทันที — ต้องล้าง field ใน Firestore เอง)')) return;
    const origText = btn.innerText;
    btn.disabled = true; btn.innerText = '⏳';
    try {
      const fb = window._fb;
      await fb.updateDoc(fb.doc(fb.db, 'contracts', contractId), { movedOutOfRecovery: true, movedOutAt: new Date().toISOString() });
      const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : (window.allContracts||[]));
      const idx = contracts.findIndex(x => x.id === contractId);
      if (idx >= 0) contracts[idx].movedOutOfRecovery = true;
      if (window.allContracts) {
        const i2 = window.allContracts.findIndex(x => x.id === contractId);
        if (i2 >= 0) window.allContracts[i2].movedOutOfRecovery = true;
      }
      window.renderRecoveryPage();
    } catch(e) {
      alert('ย้ายไม่สำเร็จ: ' + e.message);
      btn.innerText = origText; btn.disabled = false;
    }
  };

  // ESC = close
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') {
      const page = document.getElementById('recoveryPage');
      if (page && page.classList.contains('open')) window.closeRecoveryPage();
      const slm = document.getElementById('sendLineModal');
      if (slm && slm.classList.contains('open')) window.closeSendLine && window.closeSendLine();
    }
  });

  // ========== SEND LINE FEATURE ==========
  // URL ของ Cloud Function — แก้เป็น URL จริงหลัง deploy
  // เช่น: https://asia-southeast1-installment26-b5e82.cloudfunctions.net/sendLineReminder
  window.SEND_LINE_FN_URL = window.SEND_LINE_FN_URL || 'https://sendlinereminder-xrmefp33aa-as.a.run.app';

  let _slCurrentContractId = null;

  function _buildLineTemplate(c) {
    const monthsThai = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
    const due = c.currentDueDate ? new Date(c.currentDueDate) : new Date();
    const dueStr = due.getDate() + ' ' + monthsThai[due.getMonth()] + ' ' + (due.getFullYear() + 543);
    const monthly = Number(c.monthlyPay) || 0;
    const remain = Math.max(0, (Number(c.totalPrice)||0) - (Number(c.downPayment)||0) - (Number(c.paidTotal)||0));
    const paid = Number(c.paidTotal)||0;
    const instCount = Math.floor(paid / (monthly || 1));
    const totalInst = Number(c.installments) || 0;
    const account = c.paymentAccount || '— กรุณาติดต่อร้านเพื่อขอเลขบัญชี —';
    return ''
      + '👋 สวัสดีคุณ ' + (c.customerName || '') + '\n'
      + '\n'
      + '🔔 ครบกำหนดชำระค่างวด\n'
      + '\n'
      + '📱 สินค้า: ' + (c.productName || '-') + '\n'
      + '💰 ยอดที่ต้องชำระ: ' + monthly.toLocaleString('th-TH') + ' ฿\n'
      + '📅 ครบกำหนด: ' + dueStr + '\n'
      + '📊 งวดที่ ' + (instCount + 1) + '/' + totalInst + '\n'
      + '💵 ยอดค้างรวม: ' + remain.toLocaleString('th-TH') + ' ฿\n'
      + '\n'
      + '🏦 โอนเข้าบัญชี:\n'
      + account + '\n'
      + '\n'
      + '📸 หลังโอนแล้ว ส่งสลิปกลับมาที่ LINE นี้\n'
      + 'ระบบจะตรวจสอบและบันทึกอัตโนมัติ\n'
      + '\n'
      + 'ขอบคุณค่ะ 🙏';
  }

  window.openSendLine = function(contractId){
    const contracts = (typeof window._getContracts === 'function' ? window._getContracts() : (window.allContracts||[]));
    const c = contracts.find(x => x.id === contractId);
    if (!c) return alert('ไม่พบสัญญา');
    if (!c.lineUserId) return alert('สัญญานี้ยังไม่มี LINE User ID\nกรุณาแก้ไขสัญญาแล้วเพิ่ม LINE User ID ก่อน');

    _slCurrentContractId = contractId;
    document.getElementById('slCust').innerHTML = '<b>' + (c.customerName||'-') + '</b> · ' + (c.productName||'-') + '<br><span style="font-size:11px;color:#16A34A;">LINE: ' + (c.lineUserId.substring(0, 20)) + '...</span>';
    document.getElementById('slMessage').value = _buildLineTemplate(c);
    document.getElementById('sendLineModal').classList.add('open');
  };

  window.closeSendLine = function(){
    document.getElementById('sendLineModal').classList.remove('open');
    _slCurrentContractId = null;
  };

  window.doSendLine = async function(){
    const contractId = _slCurrentContractId;
    const message = document.getElementById('slMessage').value.trim();
    if (!contractId) return;
    if (!message) return alert('ข้อความว่างค่ะ');

    const btn = document.getElementById('slSendBtn');
    const orig = btn.innerText;
    btn.disabled = true; btn.innerText = '⏳ กำลังส่ง...';
    try {
      const res = await fetch(window.SEND_LINE_FN_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contractId, message })
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || data.ok === false) {
        throw new Error(data.error || ('HTTP ' + res.status));
      }
      // toast
      const t = document.createElement('div');
      t.innerHTML = '<b style="color:white;">ส่ง LINE สำเร็จ</b><br><span style="font-size:11.5px;color:rgba(255,255,255,.85);">ลูกค้าจะได้รับข้อความใน LINE</span>';
      t.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#06C755;padding:14px 22px;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.3);z-index:99999;font-family:Kanit;color:white;font-size:13px;';
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 2500);
      window.closeSendLine();
    } catch(e) {
      console.error('[sendLine]', e);
      alert('ส่งไม่สำเร็จ: ' + e.message + '\n\n• เช็คว่า Cloud Function deploy แล้ว\n• เช็ค URL ใน SEND_LINE_FN_URL\n• เช็ค LINE_TOKEN ใน .env');
      btn.innerText = orig; btn.disabled = false;
    }
  };
})();
</script>
