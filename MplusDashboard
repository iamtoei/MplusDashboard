                    h += '<div style="font-size:11px;color:#64748B;">' + (c.contractDate||'-') + ' · ' + pct + '%' + tag + '</div></div>';
                    h += '<button onclick="window.deleteDupContract(\'' + c.id + '\',\'' + sn + '\',\'' + (c.customerName||'').replace(/'/g,'') + '\')" style="background:#DC2626;color:white;border:none;border-radius:7px;padding:5px 12px;font-family:Kanit;font-size:11px;font-weight:700;cursor:pointer;margin-left:8px;">ลบ</button>';
