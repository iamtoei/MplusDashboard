                        <div style="font-size:11px;color:#94A3B8;margin-top:2px;">${dateStr}</div>
                    </div>
                    <div style="position:absolute;top:8px;right:10px;font-size:13px;font-weight:700;color:#DC2626;z-index:3;">${amt.toLocaleString()} ฿</div>
                </div>`;
            }
            if (isAmend) {
                return `<div style="padding:10px 14px;border-radius:10px;margin-bottom:8px;background:linear-gradient(135deg,#E0F2FE,#BAE6FD);border-left:4px solid #0284C7;">
                    <div style="font-size:12px;font-weight:700;color:#0369A1;margin-bottom:2px;">ปรับสัญญา</div>
                    <div style="font-size:12px;color:#0C4A6E;">${log.note||''}</div>
                    <div style="font-size:11px;color:#64748B;margin-top:2px;">${dateStr}</div>
                </div>`;
            }
            if (isAdj) {
                return `<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 12px;border-radius:10px;margin-bottom:8px;background:#FFFBEB;border-left:4px solid #F59E0B;">
                    <div><div style="font-size:13px;font-weight:600;color:#B45309;">${log.note||'ยอดปรับปรุง'}</div><div style="font-size:11px;color:var(--text-sub);">${dateStr}</div></div>
                    <span style="font-size:15px;font-weight:600;color:#B45309;">-${amt.toLocaleString()} ฿</span>
                </div>`;
            }
            return `<div style="display:flex; justify-content:space-between; align-items:center; padding:10px 12px; border-radius:10px; margin-bottom:8px; background:${isFine ? '#FEF2F2' : '#F0FDF4'}; border-left:4px solid ${isFine ? 'var(--danger)' : 'var(--success)'};">
