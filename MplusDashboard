<!-- ============= DASHBOARD OVERVIEW + P&L SCRIPT (เพิ่มใหม่) ============= -->
<script>
(function(){
    'use strict';
    let _chartsLoaded = false;
    let _chartInstances = {};
    let _expenses = [];           // ข้อมูลรายจ่าย (cache)
    let _expensesLoaded = false;
    let _currentView = 'overview';
    let _currentRange = '7d';
    let _plMonth = '';            // YYYY-MM ของเดือนที่เลือกในหน้า P&L
    let _plBranch = '';

    function loadChartJs() {
        return new Promise((resolve, reject) => {
            if (_chartsLoaded || (typeof window.Chart !== 'undefined')) { _chartsLoaded = true; resolve(); return; }
            const s = document.createElement('script');
            s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js';
            s.onload = () => { _chartsLoaded = true; resolve(); };
            s.onerror = () => reject(new Error('โหลด Chart.js ไม่สำเร็จ'));
            document.head.appendChild(s);
        });
    }

    function getContracts() {
        if (typeof window._getContracts === 'function') return window._getContracts() || [];
        return window.allContracts || [];
    }

    function filterByRange(contracts, range) {
        const now = new Date();
        let from = null;
        if (range === 'today') from = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        else if (range === '7d') from = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 6);
        else if (range === 'month') from = new Date(now.getFullYear(), now.getMonth(), 1);
        if (!from) return contracts;
        return contracts.filter(c => {
            const d = c.contractDate || c.createdAt || c.date || c.signedAt;
            if (!d) return false;
            const t = (typeof d === 'string') ? new Date(d) : (d.toDate ? d.toDate() : new Date(d));
            return t >= from;
        });
    }

    function daysOverdue(c) {
        if (!c.currentDueDate) return 0;
        const due = new Date(c.currentDueDate);
        const now = new Date();
        return Math.max(0, Math.floor((now - due) / 86400000));
    }

    const fmt = n => '฿ ' + Math.round(Number(n)||0).toLocaleString('th-TH');
    const fmtShort = n => {
        const x = Math.round(Number(n)||0);
        if (Math.abs(x) >= 1_000_000) return (x/1_000_000).toFixed(1)+'ล';
        if (Math.abs(x) >= 1_000) return (x/1_000).toFixed(0)+'K';
        return x.toLocaleString('th-TH');
    };
    const ymOf = d => {
        const dt = (typeof d === 'string') ? new Date(d) : (d.toDate ? d.toDate() : new Date(d));
        if (isNaN(dt)) return '';
        return dt.getFullYear() + '-' + String(dt.getMonth()+1).padStart(2,'0');
    };

    /* ==================== แสดง Dashboard ==================== */
    window.showDashboardOverview = async function(btn) {
        const container = document.querySelector('#dashboard .container');
        if (!container) return;
        container.classList.add('overview-active');
        document.querySelectorAll('.sidebar-btn').forEach(b => b.classList.remove('active'));
        if (btn) btn.classList.add('active');
        if (window.innerWidth < 768 && typeof window.closeSidebarMobile === 'function') window.closeSidebarMobile();
        const main = document.querySelector('.main-content');
        if (main && main.scrollTo) main.scrollTo({top:0});
        window.scrollTo({top:0});

        try {
            await loadChartJs();
            await ensureExpensesLoaded();
            initPlMonthOptions();
            initPlBranchOptions();
            renderAll();
        } catch (e) {
            console.error(e);
            const grid = document.getElementById('dovKpiGrid');
            if (grid) grid.insertAdjacentHTML('beforebegin',
                '<div style="padding:16px;background:#FEE2E2;color:#B91C1C;border-radius:12px;margin-bottom:14px;">โหลดกราฟไม่สำเร็จ — ' + (e.message||'ตรวจสอบอินเทอร์เน็ต') + '</div>');
        }
    };

    /* ==================== สลับ View Overview/P&L/Marketing ==================== */
    window._dovSwitchView = function(view) {
        _currentView = view;
        const body = document.querySelector('.dov-view-body');
        if (body) body.dataset.view = view;
        document.querySelectorAll('.dov-view-tab').forEach(t => t.classList.toggle('active', t.dataset.view === view));
        if (view === 'pnl') renderPnL();
        else if (view === 'marketing') {
            loadChartJs().then(() => {
                if (typeof window.renderMarketing === 'function') setTimeout(window.renderMarketing, 30);
            }).catch(err => console.error('[Marketing] Chart.js load failed:', err));
        }
        else renderOverview();
    };

    /* ==================== ปิด overview เมื่อสลับ tab อื่น ==================== */
    function wrapChangeTab() {
        if (window.__dovChangeTabWrapped) return;
        const _orig = window.changeTab;
        if (typeof _orig !== 'function') { setTimeout(wrapChangeTab, 100); return; }
        window.changeTab = function(tab, el) {
            const c = document.querySelector('#dashboard .container');
            if (c) c.classList.remove('overview-active');
            return _orig.apply(this, arguments);
        };
        window.__dovChangeTabWrapped = true;
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', wrapChangeTab);
    else wrapChangeTab();

    window._dovGotoAll = function() {
        const allBtn = Array.from(document.querySelectorAll('.sidebar-btn'))
            .find(b => /changeTab\(['"]all['"]/.test(b.getAttribute('onclick') || ''));
        if (allBtn) allBtn.click();
        else {
            const c = document.querySelector('#dashboard .container');
            if (c) c.classList.remove('overview-active');
        }
    };

    /* ==================== Range chips ==================== */
    document.addEventListener('click', (e) => {
        const chip = e.target.closest('#dovRangeChips .dov-chip');
        if (!chip) return;
        document.querySelectorAll('#dovRangeChips .dov-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        _currentRange = chip.dataset.range;
        if (_chartsLoaded && _currentView === 'overview') renderOverview();
    });

    /* ==================== FIX: ปุ่มลบในประวัติการจ่าย ====================
       (เดิม inline onclick แตกเมื่อชื่อลูกค้ามีอักขระพิเศษ
        เช่น "'", '"', emoji — เปลี่ยนเป็น data-attribute + delegated handler) */
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-del-paylog');
        if (!btn) return;
        e.preventDefault();
        const ds = btn.dataset;
        const amount = Number(ds.amount) || 0;
        const customer = ds.customer || '';
        const contractId = ds.contractId || '';
        if (ds.mode === 'byid' && typeof window.deleteLog === 'function') {
            window.deleteLog(ds.logId, amount, contractId, customer);
        } else if (ds.mode === 'bymatch' && typeof window.deleteLogByMatch === 'function') {
            window.deleteLogByMatch(contractId, amount, ds.type || 'installment', ds.timestamp || '', customer);
        } else {
            alert('ไม่พบฟังก์ชันลบประวัติ — กรุณา refresh หน้า');
        }
    });

    /* ==================== EXPENSE — Firebase CRUD ==================== */
    async function ensureExpensesLoaded() {
        if (_expensesLoaded) return;
        if (!window._fb || !window._fb.db) { console.warn('[dov] Firebase ยังไม่พร้อม'); _expenses = []; _expensesLoaded = true; return; }
        try {
            const { db, collection, getDocs } = window._fb;
            const snap = await getDocs(collection(db, 'expenses'));
            _expenses = snap.docs.map(d => ({ id: d.id, ...d.data() }));
            _expensesLoaded = true;
        } catch (e) {
            console.error('[dov] โหลดรายจ่ายไม่ได้:', e);
            _expenses = [];
            _expensesLoaded = true;
        }
    }

    window._dovOpenExpenseModal = function(id) {
        const m = document.getElementById('dovExpenseModal');
        if (!m) return;
        m.classList.add('show');
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('dovExpId').value = id || '';
        document.getElementById('dovExpenseModalTitle').textContent = id ? 'แก้ไขรายจ่าย' : '+ เพิ่มรายจ่าย';

        // populate branch dropdown from contracts
        const sel = document.getElementById('dovExpBranch');
        const branches = [...new Set(getContracts().map(c => c.branchId).filter(Boolean))].sort();
        sel.innerHTML = '<option value="">ส่วนกลาง / ไม่ระบุ</option>' + branches.map(b => `<option value="${b}">${b}</option>`).join('');

        if (id) {
            const ex = _expenses.find(x => x.id === id);
            if (ex) {
                document.getElementById('dovExpDate').value = ex.date || today;
                document.getElementById('dovExpCategory').value = ex.category || 'other';
                document.getElementById('dovExpBranch').value = ex.branchId || '';
                document.getElementById('dovExpAmount').value = ex.amount || '';
                document.getElementById('dovExpNote').value = ex.note || '';
            }
        } else {
            document.getElementById('dovExpDate').value = today;
            document.getElementById('dovExpCategory').value = 'salary';
            document.getElementById('dovExpBranch').value = '';
            document.getElementById('dovExpAmount').value = '';
            document.getElementById('dovExpNote').value = '';
        }
    };

    window._dovCloseExpenseModal = function() {
        const m = document.getElementById('dovExpenseModal');
        if (m) m.classList.remove('show');
    };

    window._dovSaveExpense = async function() {
        if (!window._fb || !window._fb.db) { alert('Firebase ยังไม่พร้อม กรุณา refresh หน้า'); return; }
        const id = document.getElementById('dovExpId').value;
        const date = document.getElementById('dovExpDate').value;
        const category = document.getElementById('dovExpCategory').value;
        const branchId = document.getElementById('dovExpBranch').value;
        const amount = Number(document.getElementById('dovExpAmount').value) || 0;
        const note = document.getElementById('dovExpNote').value.trim();
        if (!date) { alert('กรุณาใส่วันที่'); return; }
        if (amount <= 0) { alert('กรุณาใส่จำนวนเงินมากกว่า 0'); return; }
        const data = { date, category, branchId, amount, note, updatedAt: new Date().toISOString() };
        try {
            const { db, collection, addDoc, updateDoc, doc } = window._fb;
            if (id) {
                await updateDoc(doc(db, 'expenses', id), data);
                _expenses = _expenses.map(x => x.id === id ? { ...x, ...data } : x);
            } else {
                data.createdAt = new Date().toISOString();
                const ref = await addDoc(collection(db, 'expenses'), data);
                _expenses.push({ id: ref.id, ...data });
            }
            window._dovCloseExpenseModal();
            renderPnL();
        } catch (e) {
            console.error(e);
            alert('บันทึกไม่สำเร็จ: ' + e.message);
        }
    };

    window._dovDeleteExpense = async function(id) {
        if (!confirm('ลบรายการนี้?')) return;
        try {
            const { db, deleteDoc, doc } = window._fb;
            await deleteDoc(doc(db, 'expenses', id));
            _expenses = _expenses.filter(x => x.id !== id);
            renderPnL();
        } catch (e) {
            alert('ลบไม่สำเร็จ: ' + e.message);
        }
    };

