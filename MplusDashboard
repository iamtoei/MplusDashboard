    window.undoRefinance = async (contractId, logId) => {
        if (!confirm(' ยืนยันยกเลิกรีไฟแนนซ์?\n\nระบบจะคืนยอดชำระและลบรายการรียอด')) return;
        const d = cachedContracts.find(c => c.id === contractId);
        if (!d) { alert('ไม่พบสัญญา'); return; }
        let revLog = logId ? cachedLogs.find(l => l.id === logId) : null;
        if (!revLog) {
            const revLogs = cachedLogs.filter(l => l.contractId === contractId && l.type === 'reversal')
                .sort((a,b) => (b.timestamp||'').localeCompare(a.timestamp||''));
            revLog = revLogs[0];
        }
        if (!revLog) { alert('ไม่พบข้อมูลรียอด'); return; }
        const mPayRestore = Math.abs(Number(revLog.amount)||0);
        if (!mPayRestore) { alert('ยอดรียอดเป็น 0'); return; }
        const newPaidTotal = (Number(d.paidTotal)||0) + mPayRestore;
        const curDue = d.currentDueDate ? new Date(d.currentDueDate) : new Date();
        const restoredDue = new Date(curDue);
        restoredDue.setMonth(restoredDue.getMonth() - 1);
        restoredDue.setHours(12, 0, 0, 0);
        try {
            await updateDoc(doc(db, 'contracts', contractId), { paidTotal: newPaidTotal, currentDueDate: restoredDue.toISOString() });
            await deleteDoc(doc(db, 'payment_logs', revLog.id));
            const revDate = (revLog.timestamp||'').slice(0,10);
            const refundLog = cachedLogs.find(l => l.contractId === contractId && l.type === 'refund' && (l.timestamp||'').slice(0,10) === revDate);
            if (refundLog) await deleteDoc(doc(db, 'payment_logs', refundLog.id));
            cachedContracts = cachedContracts.map(c => c.id === contractId ? {...c, paidTotal: newPaidTotal, currentDueDate: restoredDue.toISOString()} : c);
            cachedLogs = cachedLogs.filter(l => l.id !== revLog.id && (!refundLog || l.id !== refundLog.id));
