                y += 52;
            });
            y += 8;
        };
        section('ได้เครื่อง', '#22C55E', gotList, '#22C55E');
        section('จ่ายเงิน', '#1E3A8A', paidList, '#1E3A8A');
        section(' ต้องติดตามต่อ', '#A78BFA', followList, '#A78BFA');
        y += 4; ctx.strokeStyle = '#2D3548'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(24,y); ctx.lineTo(W-24,y); ctx.stroke();
        txt('รวม ' + data.length + ' รายการ  |  MPLUS SYSTEM', W/2, y+22, '12px Kanit, sans-serif', '#475569', 'center');
        const link = document.createElement('a');
        link.download = 'tracking_' + now.replace(/\s/g,'_') + '.png';
        link.href = canvas.toDataURL('image/png'); link.click();
