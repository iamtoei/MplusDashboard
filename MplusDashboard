  let mkCharts={};

  function mkGetData(){return _mkFilter==='all'?MK_DATA:MK_DATA.filter(r=>r.branch===_mkFilter);}
  function mkFmt(n){return '฿ '+Math.round(Number(n)||0).toLocaleString('th-TH');}
  function mkFmtShort(n){const x=Math.round(Number(n)||0);if(x>=1e6)return(x/1e6).toFixed(1)+'ล';if(x>=1e3)return(x/1e3).toFixed(0)+'K';return x.toLocaleString('th-TH');}
  function mkPct(n,t){return t>0?(n/t*100).toFixed(1):0;}
  function mkRevenue(r){return r.saleType==='ขายผ่อน'?(r.down||0)+((r.monthly||0)*12):(r.price||r.down||0);}
  function mkCountBy(rows,key){const c={};rows.forEach(r=>{const v=r[key]||'ไม่ระบุ';c[v]=(c[v]||0)+1;});return c;}
  function mkSumBy(rows,key,fn){const c={};rows.forEach(r=>{const v=r[key]||'ไม่ระบุ';c[v]=(c[v]||0)+fn(r);});return c;}
  function mkDestroy(k){if(mkCharts[k]){try{mkCharts[k].destroy();}catch(e){}delete mkCharts[k];}}

  function mkRenderKPIs(data){
    const total=data.length;
    const totalRev=data.reduce((s,r)=>s+mkRevenue(r),0);
    const ch=mkCountBy(data,'channel');
    const topCh=Object.entries(ch).sort((a,b)=>b[1]-a[1])[0];
    const age=mkCountBy(data,'age');delete age['ไม่ระบุ'];
    const topAge=Object.entries(age).sort((a,b)=>b[1]-a[1])[0];
    document.getElementById('mkKpiTotal').textContent=total.toLocaleString('th-TH');
    document.getElementById('mkKpiTotalSub').textContent='จาก '+MK_DATA.length.toLocaleString('th-TH')+' รายการ';
    document.getElementById('mkKpiRevenue').textContent=mkFmt(totalRev);
    document.getElementById('mkKpiRevenueSub').textContent='เฉลี่ย '+mkFmt(totalRev/Math.max(1,total))+'/ราย';
    if(topCh){document.getElementById('mkKpiTopChannel').textContent=topCh[0];document.getElementById('mkKpiTopChannelSub').textContent=topCh[1]+' ราย ('+mkPct(topCh[1],total)+'%)';}
    if(topAge){document.getElementById('mkKpiTopAge').textContent=topAge[0];document.getElementById('mkKpiTopAgeSub').textContent=topAge[1]+' ราย ('+mkPct(topAge[1],total)+'%)';}
  }

