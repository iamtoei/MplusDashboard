<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MPLUS System</title>
    <!-- PWA — ทำงานบน iOS Safari และ Android Chrome -->
    <meta name="theme-color" content="#1E3A8A">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="MPLUS">
    <link rel="apple-touch-icon" sizes="180x180" href="icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="icon.png">
    <link rel="manifest" href="manifest.json">
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>

    <style>
        :root {
            --primary-orange: #1D4ED8; --primary-orange-soft: #EFF6FF; --primary-orange-deep: #1E3A8A;
            --accent: #1D4ED8; --accent-soft: #EFF6FF; --accent-deep: #1E3A8A;
            --deep-slate: #1E293B; --slate-2: #334155; --soft-bg: #F8FAFC; --white: #FFFFFF;
            --success: #15803D; --danger: #B91C1C; --text-main: #0F172A; --text-sub: #475569;
            --border-soft: #E2E8F0; --border: #CBD5E1;
            --shadow-xs: 0 1px 2px rgba(15,23,42,0.04);
            --shadow-sm: 0 1px 4px rgba(15,23,42,0.06), 0 1px 2px rgba(15,23,42,0.03);
            --shadow-md: 0 4px 12px rgba(15,23,42,0.07), 0 2px 4px rgba(15,23,42,0.04);
            --shadow-lg: 0 12px 32px rgba(15,23,42,0.10), 0 4px 10px rgba(15,23,42,0.05);
            --shadow-orange: 0 4px 12px rgba(29,78,216,0.22);
            --recovery-bg: #DC6B4E; --recovery-row: #FFF5F2;
            --grade-green: #22C55E; --grade-yellow: #EAB308; --grade-orange: #F97316; --grade-red: #EF4444; --grade-black: #1E293B; --grade-mblack: #000000; --grade-gray: #6B7280; --grade-blue: #0EA5E9;
            --sidebar-width: 220px;
        }
        body { margin:0; font-family:'Kanit',sans-serif; background: var(--soft-bg); color: var(--text-main); display: flex; min-height: 100vh; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
        .sidebar { width: var(--sidebar-width); background: var(--deep-slate); height: 100vh; position: fixed; left: 0; top: 0; padding: 24px 12px 20px; color: white; overflow-y: auto; z-index: 1000; transition: 0.3s; box-shadow: 4px 0 24px rgba(0,0,0,0.08); }
        .sidebar::-webkit-scrollbar { width: 6px; }
        .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 99px; }
        .sidebar.collapsed { left: calc(var(--sidebar-width) * -1); }
        .sidebar .logo { font-size: 20px; font-weight: 800; margin-bottom: 24px; text-align: center; letter-spacing: -0.4px; }
        .sidebar .logo span { color: var(--primary-orange); }
        .sidebar-label { font-size: 9.5px; color: #475569; text-transform: uppercase; margin: 22px 0 6px 14px; display: block; letter-spacing: 1.6px; font-weight: 600; opacity: 0.85; }
        .sidebar-label:first-of-type { margin-top: 8px; }
        .sidebar-btn { width: 100%; padding: 9px 13px; border-radius: 9px; border: none; background: transparent; color: #64748B; text-align: left; cursor: pointer; font-family: 'Kanit'; font-size: 13px; transition: all 0.18s ease; display: flex; align-items: center; gap: 9px; margin-bottom: 1px; position: relative; line-height: 1.4; }
        .sidebar-btn:hover { background: rgba(255,255,255,0.04); color: #E2E8F0; }
        .sidebar-btn.active {
            background: rgba(59,130,246,0.18);
            color: #93C5FD !important;
            font-weight: 700;
            box-shadow: inset 3px 0 0 #3B82F6;
        }
        .sidebar-btn.active:hover { background: rgba(59,130,246,0.24); }
        .toggle-btn { position: fixed; right: 20px; bottom: 20px; z-index: 2000; background: var(--primary-orange); color: white; width: 52px; height: 52px; border-radius: 50%; border: none; cursor: pointer; display: none; align-items: center; justify-content: center; font-size: 22px; box-shadow: var(--shadow-orange); transition: transform 0.2s; }
        .toggle-btn:active { transform: scale(0.95); }
@media (max-width: 768px) { .toggle-btn { display: flex !important; } }
        .main-content { flex-grow: 1; margin-left: var(--sidebar-width); padding: 16px 22px; box-sizing: border-box; transition: 0.3s; width: calc(100% - var(--sidebar-width)); }
        .main-content.expanded { margin-left: 0; width: 100%; }
        .container { max-width: 1440px; margin: auto; }
        .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 8px; margin-bottom: 10px; }
        .summary-card {
            background: var(--white);
            padding: 10px 14px;
            border-radius: 10px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-soft);
            transition: box-shadow 0.18s ease;
            position: relative;
            overflow: hidden;
        }
        .summary-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            background: var(--primary-orange);
            opacity: 0;
            transition: opacity 0.18s;
        }
        .summary-card:hover { box-shadow: var(--shadow-md); }
        .summary-card:hover::before { opacity: 1; }
        /* Colorful top accent per card position (first-row KPIs) */
        .summary-grid:not(#typeBreakdown) > .summary-card:nth-child(1)::before { background: #0EA5E9; opacity: 1; }
        .summary-grid:not(#typeBreakdown) > .summary-card:nth-child(2)::before { background: var(--primary-orange); opacity: 1; }
        .summary-grid:not(#typeBreakdown) > .summary-card:nth-child(3)::before { background: #22C55E; opacity: 1; }
        .summary-grid:not(#typeBreakdown) > .summary-card:nth-child(4)::before { background: #EF4444; opacity: 1; }
        .summary-grid:not(#typeBreakdown) > .summary-card:nth-child(5)::before { background: #8B5CF6; opacity: 1; }
        .summary-label { font-size: 10px; font-weight: 700; color: var(--text-sub); display: block; margin-bottom: 4px; letter-spacing: 0.4px; text-transform: uppercase; }
        .summary-val { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; color: var(--text-main); line-height: 1.15; }
        .toolbar { display: flex; gap: 6px; align-items: center; margin-bottom: 10px; flex-wrap: wrap; }
        .search-wrap { flex-grow: 1; min-width: 260px; position: relative; }
        .search-wrap input { width: 100%; padding: 13px 42px 13px 16px; border-radius: 12px; border: 1.5px solid var(--border); outline: none; box-sizing: border-box; font-family: 'Kanit'; font-size: 14px; background: var(--white); transition: border-color 0.15s, box-shadow 0.15s; }
        .search-wrap input:focus { border-color: var(--primary-orange); box-shadow: 0 0 0 4px rgba(255,159,28,0.12); }
        .search-clear { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: #CBD5E1; border: none; border-radius: 50%; width: 22px; height: 22px; cursor: pointer; font-size: 11px; color: white; display: none; align-items: center; justify-content: center; line-height: 1; padding: 0; font-weight: 700; }
        .search-clear:hover { background: #94A3B8; }
        .table-wrap { background: var(--white); border-radius: 12px; box-shadow: var(--shadow-sm); overflow-y: auto; max-height: 70vh; border: 1px solid var(--border-soft); }
        table { width: 100%; border-collapse: separate; border-spacing: 0; }
        th { background: #FAFBFD; padding: 9px 14px; text-align: left; font-size: 10.5px; position: sticky; top: 0; z-index: 10; border-bottom: 1px solid var(--border); color: var(--text-sub); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
        td { padding: 9px 14px; border-bottom: 1px solid var(--border-soft); font-size: 13px; vertical-align: middle; }
        tbody tr { transition: background-color 0.12s; }
        tbody tr:hover { background: #FAFBFD; }
        tbody tr:last-child td { border-bottom: none; }
        .btn-icon { padding: 7px 13px; border-radius: 8px; cursor: pointer; border: none; font-family: 'Kanit'; font-size: 12px; font-weight: 600; transition: all 0.15s ease; letter-spacing: 0.1px; }
        .btn-icon:hover { opacity: 0.88; }
        .btn-icon:active { transform: scale(0.98); }
        .btn-pay { background: #1E40AF; color: white; }
        .btn-pay:hover { background: #1E3A8A; }
        .btn-edit { background: #F1F5F9; color: var(--text-main); border: 1px solid var(--border); }
        .btn-edit:hover { background: #E9EFF6; }
        .btn-del { background: #DC2626; color: white; }
        .btn-promote { background: #F0FDF4; color: #16A34A; border: 1px solid #86EFAC; font-weight: 600; }
        .modal { position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(15,23,42,0.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); display:none; justify-content:center; align-items:center; z-index: 2000; padding: 15px; }
        .modal-box { background: white; padding: 30px; border-radius: 22px; width: 100%; max-width: 450px; max-height: 90vh; overflow-y: auto; box-shadow: var(--shadow-lg); border: 1px solid var(--border-soft); }
        input, select, textarea { padding: 12px 14px; border-radius: 11px; border: 1.5px solid var(--border); width: 100%; margin-bottom: 10px; font-family: 'Kanit'; box-sizing: border-box; background: #FAFBFD; font-size: 15px; transition: border-color 0.15s, box-shadow 0.15s, background-color 0.15s; }
        input:focus, select:focus, textarea:focus { outline: none; border-color: var(--primary-orange); background: white; box-shadow: 0 0 0 4px rgba(255,159,28,0.12); }
        .color-dot { width: 14px; height: 14px; border-radius: 50%; display: inline-block; cursor: pointer; border: 2px solid transparent; text-align: center; line-height: 14px; font-size: 10px; }
        .dot-green { background: var(--grade-green); } .dot-yellow { background: var(--grade-yellow); } .dot-orange { background: var(--grade-orange); } .dot-red { background: var(--grade-red); } .dot-black { background: var(--grade-black); } .dot-mblack { background: var(--grade-mblack); border: 1.5px solid #4B5563; } .dot-gray { background: var(--grade-gray); } .dot-blue { background: var(--grade-blue); }
        .dot-none { background: #FFF; border: 1px solid #DDD; color: #999; font-weight: bold; }
        .grade-badge { padding: 3px 9px; border-radius: 999px; font-size: 10px; color: white; display: inline-block; margin-top: 4px; font-weight: 600; letter-spacing: 0.2px; }
        .profit-box { background: linear-gradient(135deg, #F8FAFC, #F1F5F9); padding: 16px 18px; border-radius: 14px; margin-bottom: 15px; border: 1px solid var(--border-soft); }
        .profit-row { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 14px; }
        .profit-final { font-size: 19px; font-weight: 700; text-align: center; margin-top: 10px; padding-top: 12px; border-top: 1px dashed var(--border); letter-spacing: -0.3px; }
        .page-btn {
            padding: 9px 15px;
            margin: 0 3px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: white;
            cursor: pointer;
            font-family: 'Kanit';
            font-size: 13px;
            font-weight: 500;
            transition: 0.15s all;
            color: var(--text-main);
        }
        .page-btn:hover:not(:disabled) {
            background: var(--primary-orange-soft);
            border-color: var(--primary-orange);
            color: var(--primary-orange-deep);
        }
        .page-btn.active {
            background: #1E40AF;
            color: white;
            border-color: #1E40AF;
            font-weight: 700;
            box-shadow: 0 3px 8px rgba(30,64,175,0.30);
        }
        .page-btn.special {
            background: #F8FAFC;
            font-weight: 500;
        }
        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        /* ===== MOBILE / TABLET RESPONSIVE ===== */
        /* iPad + mobile: ซ่อน sidebar, ใช้ overlay แทน */
        @media (max-width: 1024px) {
            .sidebar { display: none !important; }
            .main-content { margin-left: 0 !important; width: 100% !important; padding: 12px !important; }
            .toggle-btn { display: flex !important; }
            .summary-grid { grid-template-columns: 1fr 1fr !important; gap: 8px !important; }
            .summary-card { padding: 10px !important; }
            .summary-val { font-size: 14px !important; }
            .summary-label { font-size: 10px !important; }
            #typeBreakdown { display: none !important; }
            .toolbar { gap: 6px !important; }
            .search-wrap { min-width: 100% !important; order: -1; }
            .table-wrap { border-radius: 12px !important; max-height: 70vh !important; }
            th, td { padding: 8px 10px !important; font-size: 12px !important; }
            .btn-icon { padding: 5px 7px !important; font-size: 10px !important; }
            .header-nav { flex-direction: column; gap: 10px; align-items: flex-start !important; }
            .header-nav div:last-child { width: 100%; justify-content: flex-end; }
            #revMode, #revDate, #branchFilter { display: none !important; }
            /* iOS: ป้องกัน auto-zoom เมื่อโฟกัส input */
            input, select, textarea { font-size: 16px !important; }
            /* touch target ขนาดใหญ่พอ */
            button, .btn-icon { min-height: 40px; touch-action: manipulation; }
        }
        @media (max-width: 768px) {
            th:nth-child(3), th:nth-child(4), td:nth-child(3), td:nth-child(4) { display: none; }
        }
        @media (max-width: 480px) {
            th:nth-child(5), td:nth-child(5) { display: none; }
            .btn-icon:not(.btn-pay):not(.btn-del):not(.btn-quickedit):not(.btn-promote) { display: none; }
            .btn-pay, .btn-del, .btn-quickedit, .btn-promote { display: inline-block !important; }
        }
        /* Sidebar overlay (iPad + mobile) */
        @media (max-width: 1024px) {
            .sidebar.mobile-open {
                display: block !important;
                position: fixed; left: 0; top: 0;
                z-index: 9000;
                box-shadow: 4px 0 20px rgba(0,0,0,0.5);
            }
            .sidebar-overlay {
                display: none;
                position: fixed; inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 8999;
            }
            .sidebar-overlay.active { display: block; }
        }
        /* ============================================================
           MOBILE / TABLET UI — รองรับ iPhone + iPad
           ============================================================ */
        /* Modal → Bottom Sheet บน mobile/tablet */
        @media (max-width: 1024px) {
            .modal {
                align-items: flex-end !important;
                padding: 0 !important;
            }
            .modal-box {
                border-radius: 24px 24px 0 0 !important;
                max-width: 100% !important;
                width: 100% !important;
                max-height: 92vh !important;
                padding: 20px 16px 32px !important;
                animation: slideUp 0.25s ease;
            }
            @keyframes slideUp {
                from { transform: translateY(100%); opacity: 0; }
                to   { transform: translateY(0);    opacity: 1; }
            }
            /* Bottom sheet handle */
            .modal-box::before {
                content: '';
                display: block;
                width: 40px;
                height: 4px;
                background: #CBD5E1;
                border-radius: 2px;
                margin: 0 auto 16px;
            }
            /* Toolbar จัดใหม่ */
            .toolbar {
                display: grid !important;
                grid-template-columns: 1fr auto !important;
                gap: 8px !important;
                align-items: center;
            }
            .search-wrap { grid-column: 1 / -1; order: -1 !important; }
            /* ซ่อนปุ่มรองบน toolbar */
            #bossReportBtn, #returnedReportBtn,
            #forecastBtn, #branchSummaryBtn, #excelExportBtn,
            #excelImportBtn, #excelSalesImportBtn,
            #addBranchBtn, #manageUsersBtn, #bulkDeleteBtn, #bulkFixBtn {
                display: none !important;
            }
            /* เหลือแค่ปุ่มหลัก */
            #addContractBtn {
                padding: 10px 16px !important;
                font-size: 13px !important;
            }
            /* Header compact */
            .header-nav {
                margin-bottom: 16px !important;
            }
            .header-nav div:first-child {
                font-size: 16px !important;
            }
            /* Summary cards - 2 คอลัมน์ ขนาดพอดี */
            .summary-grid {
                grid-template-columns: 1fr 1fr !important;
                gap: 8px !important;
            }
            /* Pagination ปุ่มใหญ่ขึ้น */
            .page-btn {
                min-width: 44px !important;
                min-height: 44px !important;
                font-size: 14px !important;
                padding: 8px 12px !important;
            }
            /* ซ่อนหัวตาราง (ใช้ card แทน) */
            .table-wrap thead { display: none !important; }
            /* FAB ปุ่ม + เพิ่มสัญญา ลอยมุมล่างขวา */
            #fabAddBtn { display: flex !important; }
            /* ปุ่ม pay ใหญ่ขึ้น กดง่ายขึ้น */
            .mobile-pay-btn {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                width: 100%;
                padding: 14px !important;
                font-size: 15px !important;
                font-weight: 700 !important;
                border-radius: 12px !important;
                min-height: 48px;
            }
        }
        /* FAB Button */
        #fabAddBtn {
            display: none;
            position: fixed;
            right: 20px;
            bottom: calc(76px + env(safe-area-inset-bottom));
            z-index: 1500;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: var(--primary-orange);
            color: white;
            border: none;
            font-size: 26px;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(255,159,28,0.5);
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }
        #fabAddBtn:active { transform: scale(0.92); }
        /* Bottom Nav Bar บน mobile + tablet */
        #mobileBottomNav {
            display: none;
        }
        @media (max-width: 1024px) {
            #mobileBottomNav {
                display: flex;
                position: fixed;
                bottom: 0; left: 0; right: 0;
                background: #1A1F2C;
                z-index: 1400;
                border-top: 1px solid rgba(255,255,255,0.08);
                padding: 0;
                height: 64px;
                /* iOS safe area */
                padding-bottom: env(safe-area-inset-bottom);
            }
            .mob-nav-btn {
                flex: 1;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 3px;
                background: none;
                border: none;
                color: #94A3B8;
                font-family: 'Kanit';
                font-size: 10px;
                cursor: pointer;
                transition: color 0.2s;
                padding: 8px 0;
                min-height: 44px;
            }
            .mob-nav-btn .nav-icon { font-size: 22px; }
            .mob-nav-btn.active { color: var(--primary-orange); }
            /* เว้นพื้นที่ให้ bottom nav + iOS home indicator */
            .main-content {
                padding-bottom: calc(80px + env(safe-area-inset-bottom)) !important;
            }
        }
        /* ===== iOS Standalone / PWA ===== */
        /* padding-top สำหรับ notch เมื่อ Add to Home Screen */
        @media (display-mode: standalone) {
            body { padding-top: env(safe-area-inset-top); }
            .sidebar { padding-top: calc(24px + env(safe-area-inset-top)); }
        }
        /* Banner "เพิ่มไปยังหน้าจอโฮม" */
        #iosHintBanner {
            display: none;
            position: fixed;
            bottom: 0; left: 0; right: 0;
            z-index: 9998;
            background: #1E3A8A;
            color: white;
            padding: 14px 16px calc(14px + env(safe-area-inset-bottom));
            font-family: 'Kanit', sans-serif;
            font-size: 13px;
            align-items: center;
            gap: 10px;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
            animation: slideUpBanner 0.4s ease;
        }
        @keyframes slideUpBanner {
            from { transform: translateY(100%); }
            to   { transform: translateY(0); }
        }
        #iosHintBanner .hint-icon { font-size: 22px; flex-shrink: 0; }
        #iosHintBanner .hint-text { flex: 1; line-height: 1.4; }
        #iosHintBanner .hint-close {
            background: rgba(255,255,255,0.2); border: none; color: white;
            border-radius: 50%; width: 28px; height: 28px; font-size: 16px;
            cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
        }
        @keyframes shimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        .skel-cell {
            background: linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);
            background-size: 400% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 6px;
            height: 12px;
            display: block;
        }
        /* ===== REFRESHED HEADER / DASHBOARD TITLE ===== */
        .header-nav { margin-bottom: 16px !important; }
        .header-nav > div:first-child {
            font-size: 22px !important;
            font-weight: 800 !important;
            letter-spacing: -0.4px;
            color: var(--text-main);
        }
        .header-nav > div:first-child::before {
            content: '';
            display: inline-block;
            width: 4px;
            height: 20px;
            background: var(--primary-orange);
            border-radius: 3px;
            margin-right: 10px;
            vertical-align: middle;
        }
        /* Uniform pill-style toolbar buttons in header */
        .header-nav .btn-icon {
            border-radius: 11px !important;
            padding: 10px 16px !important;
            font-weight: 600 !important;
            font-size: 12.5px !important;
            border: 1px solid transparent;
        }
        /* Primary "เพิ่มสัญญาใหม่" button — make it pop */
        #addContractBtn {
            padding: 12px 22px !important;
            border-radius: 12px !important;
            background: linear-gradient(135deg, #FFB347 0%, var(--primary-orange) 100%) !important;
            box-shadow: var(--shadow-orange) !important;
            font-weight: 700 !important;
            letter-spacing: 0.2px;
            transition: all 0.2s ease;
        }
        #addContractBtn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(255,159,28,0.48) !important;
        }
        /* ===== TOOLBAR BUTTONS REFRESH ===== */
        .toolbar .btn-icon {
            padding: 10px 15px !important;
