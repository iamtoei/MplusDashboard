    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(regs => {
                regs.forEach(r => r.unregister());
            }).catch(() => {});
        }
        if ('caches' in window) {
            caches.keys().then(keys => {
                keys.forEach(k => caches.delete(k));
            }).catch(() => {});
        }
        // ปิด modal เมื่อแตะนอกกล่อง (click-outside)
        // ยกเว้น modal ที่กรอกฟอร์ม — กลัวปิดโดยไม่ตั้งใจ
        const NO_CLICK_OUTSIDE = ['contractModal', 'payModal', 'adjustModal', 'editModal', 'quickEditModal'];
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('modal')) {
                if (!NO_CLICK_OUTSIDE.includes(e.target.id)) {
                    e.target.style.display = 'none';
                }
            }
            // ปิด dropdown จัดการ เมื่อคลิกนอก
            if (!e.target.closest('[id^="mgr_"]')) {
                document.querySelectorAll('[id^="mgrDrop_"]').forEach(d => d.style.display = 'none');
            }
        });
        window.onTypeChange = (val) => {
            const customTypes = window.window._customTypes || [];
            const isCustom = !['normal','zero','province','down999','android','cash'].includes(val) && val !== '';
            const customType = customTypes.find(t => t.key === val);
            const costWrap = document.getElementById('cost_wrap');
            const downWrap = document.getElementById('down_wrap');
            const lblTotal = document.getElementById('lbl_total');
            const lblInstall = document.getElementById('lbl_install');
            if (isCustom && customType) {
                if (costWrap) costWrap.style.display = 'none';
                if (downWrap) downWrap.style.display = 'none';
                if (lblTotal) lblTotal.textContent = 'เงินที่ได้รับไป (฿)';
                if (lblInstall) lblInstall.textContent = 'จำนวนเดือน';
                const downEl = document.getElementById('m_down');
                if (downEl) downEl.value = '0';
            } else {
                if (costWrap) costWrap.style.display = '';
                if (downWrap) downWrap.style.display = '';
                if (lblTotal) lblTotal.textContent = 'ราคาขาย';
