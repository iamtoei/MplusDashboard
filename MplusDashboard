    function renderRecentTable(all) {
        const palette = ['#3B82F6','#10B981','#F59E0B','#EF4444','#8B5CF6','#EC4899','#06B6D4','#84CC16'];
        const typeMap = { normal:['ผ่อนปกติ','blue'], zero:['ผ่อน 0%','green'], province:['ต่างจังหวัด','blue'], down999:['ดาวน์ 999','purple'], android:['Android','green'] };
        const gradeColor = { green:'#22C55E', yellow:'#EAB308', orange:'#F97316', red:'#EF4444', black:'#1E293B', gray:'#6B7280' };
        const gradeLbl = { green:'เขียว', yellow:'เหลือง', orange:'ส้ม', red:'แดง', black:'ทำกำไร', gray:'หนี้เสีย' };
        const sorted = [...all].sort((a,b) => {
            const da = new Date(a.contractDate || a.createdAt || a.date || 0).getTime();
            const db = new Date(b.contractDate || b.createdAt || b.date || 0).getTime();
            return db - da;
        }).slice(0, 10);
        const body = document.getElementById('dovRecentBody');
        if (!body) return;
