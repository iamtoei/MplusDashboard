    async function loadAllData() {
        try {
            // GAS: โหลดทุก collection ใน 1 call (contracts + payment_logs + tracking + grade)
            updateLoadingText('กำลังโหลดข้อมูล...');
            const allData = await _gs('getAllData');
            cachedContracts = allData.contracts || [];
            cachedLogs = allData.payment_logs || [];
            if (Array.isArray(allData.tracking_logs) && typeof window.cachedTracking !== 'undefined') window.cachedTracking = allData.tracking_logs;
            if (Array.isArray(allData.grade_logs) && typeof window.cachedGradeLogs !== 'undefined') window.cachedGradeLogs = allData.grade_logs;
            contractsReady = true;
            logsReady = true;
            isCacheReady = true;
            clearTimeout(window._loadTimeout);
            window.rebuildLogsIndex && window.rebuildLogsIndex();
            showSyncStatus('online');
            renderAll();
            // FIX (cost optimization): Auto-refresh ทุก 30 นาที (จาก 5 นาที — ลด 83%)
            // + ไม่ auto-refresh payment_logs (โหลดแค่ตอนเปิดเว็บ + update cache แบบ manual เมื่อมีการจ่าย)
            // + หยุด refresh ถ้า tab hidden หรือ user inactive > 15 นาที
            // = ลด Firestore reads ~90% (จาก ~5,000฿/เดือน → ~500-800฿/เดือน)
            if (!window._autoRefreshTimer) {
                const REFRESH_INTERVAL = 30 * 60 * 1000; // 30 นาที
                const INACTIVE_TIMEOUT = 15 * 60 * 1000; // 15 นาที ไม่ขยับเมาส์/คีย์บอร์ด = inactive
                let _countdown = REFRESH_INTERVAL / 1000;
                let _consecutiveFailures = 0;
                let _lastActivity = Date.now();

                // Track user activity → ถ้าไม่ active ก็ไม่ต้องเสีย reads
                ['mousemove','keydown','click','scroll','touchstart'].forEach(evt => {
                    document.addEventListener(evt, () => { _lastActivity = Date.now(); }, { passive: true });
                });

                const doRefresh = async (force) => {
                    // หยุดถ้า tab ซ่อนอยู่ — ประหยัด reads มาก
                    if (!force && document.hidden) {
                        console.log('[AutoRefresh] Tab hidden — skipping');
                        return;
                    }
                    // หยุดถ้า user inactive นานเกิน
                    if (!force && (Date.now() - _lastActivity) > INACTIVE_TIMEOUT) {
                        console.log('[AutoRefresh] User inactive >15min — skipping');
                        return;
                    }
                    try {
                        // GAS: โหลดทุก collection ใน 1 call (ไม่มี cost per read ใน Sheets)
                        const ad2 = await _gs('getAllData');
                        const newContracts = ad2.contracts || [];
                        const newLogs = ad2.payment_logs || [];

                        // GUARD: ห้าม overwrite cache ถ้าข้อมูลหายแบบผิดปกติ
                        if (cachedContracts.length > 10 && newContracts.length === 0) {
                            console.warn('[AutoRefresh] BLOCKED: contracts returned 0');
                            showSyncStatus('error'); _consecutiveFailures++; return;
                        }
                        if (cachedContracts.length > 100 && newContracts.length < cachedContracts.length * 0.5) {
                            console.warn('[AutoRefresh] BLOCKED: suspicious data drop');
                            showSyncStatus('error'); _consecutiveFailures++; return;
                        }
                        cachedContracts = newContracts;
                        if (newLogs.length > 0) { cachedLogs = newLogs; window.rebuildLogsIndex && window.rebuildLogsIndex(); }

                        _countdown = REFRESH_INTERVAL / 1000;
                        _consecutiveFailures = 0;
                        showSyncStatus('online');
                        renderAll();
                    } catch(e) {
                        _consecutiveFailures++;
                        showSyncStatus('error');
                        console.warn('[AutoRefresh] failed (' + _consecutiveFailures + '):', e.message || e);
                    }
                };

                // expose สำหรับ manual refresh
                window._manualRefresh = async () => {
                    showSyncStatus('connecting');
                    // manual refresh = sync ทั้ง contracts + payment_logs
                    try {
                        const ad = await _gs('getAllData');
                        const nc = ad.contracts || [];
                        const nl = ad.payment_logs || [];
                        if (nc.length > 0) cachedContracts = nc;
                        if (nl.length > 0) { cachedLogs = nl; window.rebuildLogsIndex && window.rebuildLogsIndex(); }
                        _lastActivity = Date.now();
                        _countdown = REFRESH_INTERVAL / 1000;
                        showSyncStatus('online');
                        renderAll();
                        return true;
                    } catch(e) { showSyncStatus('error'); console.warn('[ManualRefresh] failed:', e); return false; }
                };

                window._autoRefreshTimer = setInterval(doRefresh, REFRESH_INTERVAL);

                // รีเฟรชทันทีเมื่อ user กลับมาที่ tab (ถ้าห่างเกิน 30 นาที)
                let _lastVisibleTime = Date.now();
                document.addEventListener('visibilitychange', async () => {
                    if (!document.hidden) {
                        const away = Date.now() - _lastVisibleTime;
                        _lastActivity = Date.now(); // กลับมาดูแล้ว = active
                        if (away > REFRESH_INTERVAL) {
                            console.log('[AutoRefresh] Tab visible after ' + Math.round(away/1000) + 's — refreshing');
                            await doRefresh(true);
                        }
                    } else {
                        _lastVisibleTime = Date.now();
                    }
                });

                // Countdown แสดงเวลา refresh ถัดไป
                window._countdownTimer = setInterval(() => {
                    _countdown--;
                    if (_countdown <= 0) _countdown = REFRESH_INTERVAL / 1000;
                    const syncEl = document.getElementById('syncStatusDot');
                    if (syncEl && syncEl.title !== undefined) {
                        const min = Math.floor(_countdown / 60);
                        const sec = _countdown % 60;
                        syncEl.title = 'อัปเดตทุก 5 นาที (อีก ' + (min > 0 ? min + 'น ' : '') + sec + 'ว)';
                    }
                }, 1000);
            }
        } catch(err) {
            console.error("Load error:", err);
            const ov = document.getElementById('loadingOverlay');
            if (ov && !isCacheReady) {
                ov.innerHTML = '<div style="text-align:center;color:white;padding:20px;">' +
                    '<div style="font-size:40px;margin-bottom:12px;"></div>' +
                    '<div style="font-size:18px;font-weight:700;margin-bottom:8px;">เชื่อมต่อช้า</div>' +
                    '<div style="font-size:13px;color:#94A3B8;margin-bottom:8px;">ข้อมูล ' + (cachedContracts.length||0) + ' รายการ</div>' +
                    '<div style="font-size:12px;color:#64748B;margin-bottom:20px;">ลองใหม่อัตโนมัติใน 15 วินาที</div>' +
                    '<button onclick="location.reload()" style="background:#1E40AF;color:white;border:none;padding:12px 28px;border-radius:50px;font-size:15px;font-family:Kanit;cursor:pointer;font-weight:700;">โหลดใหม่เลย</button>' +
                '</div>';
