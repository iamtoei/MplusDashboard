            const reader = new FileReader();
            reader.onload = async (event) => {
                try {
                    const data = new Uint8Array(event.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const rows = XLSX.utils.sheet_to_json(workbook.Sheets[workbook.SheetNames[0]]);
                    if(confirm(`ตรวจพบข้อมูลทั้งหมด ${rows.length} รายการ ยืนยันการนำเข้าหรือไม่?`)) {
                        let successCount = 0, errorCount = 0;
                        const statusDiv = document.createElement('div');
                        statusDiv.style = "position:fixed; top:20px; right:20px; background:white; padding:20px; border-radius:15px; box-shadow:0 10px 25px rgba(0,0,0,0.2); z-index:9999; border-left:5px solid var(--primary-orange);";
                        statusDiv.innerHTML = `<b>กำลังนำเข้าข้อมูล...</b><br><small id="importStatus">รอสักครู่...</small>`;
                        document.body.appendChild(statusDiv);
                        for (let i = 0; i < rows.length; i++) {
                            const row = rows[i];
                            try {
                                const getV = (keys) => { const k = Object.keys(row).find(key => keys.some(t => key.toString().toLowerCase().includes(t.toLowerCase()))); return k ? row[k] : ""; };
                                // Parse date from "Date Add" column if available
                                const dateAddRaw = getV(['Date Add', 'วันที่', 'วันที่เพิ่ม', 'date']);
                                let contractDateISO = new Date().toISOString();
                                if (dateAddRaw) { try { const d = new Date(dateAddRaw); if(!isNaN(d)) contractDateISO = d.toISOString(); } catch(e){} }
                                // IMEI: may be a large number stored as scientific notation in Excel
                                const imeiRaw = getV(['IMEI', 'imei']);
                                const imeiStr = imeiRaw ? String(Math.round(Number(imeiRaw))) : "-";
                                // Status fields from MDM
                                const lostMode = getV(['Status Lost Mode', 'Lost Mode']) || "";
                                const deletionStatus = getV(['Deletion Status', 'Deletion']) || "";
                                const abmStatus = getV(['ABM Status', 'ABM']) || "";
                                const iosVersion = getV(['iOS Version', 'iOS', 'OS Version']) || "";
                                const lastConn = getV(['Last Connection', 'Last Connect']) || "";
                                const staffUser = getV(['User', 'พนักงาน', 'ผู้บันทึก']) || "";
                                const payload = {
                                    contractNo: String(getV(['เลขที่สัญญา', 'สัญญา', 'Contract Number']) || "-"),
                                    customerName: getV(['ชื่อลูกค้า', 'ชื่อ', 'Name']) || "ไม่ระบุชื่อ",
                                    customerPhone: String(getV(['Phone Number', 'เบอร์', 'โทร', 'phone']) || "-"),
                                    productName: getV(['รุ่นสินค้า', 'รุ่น', 'Model']) || "ไม่ระบุรุ่น",
                                    sn: String(getV(['sn', 'Serial']) || "-"),
                                    imei: imeiStr,
                                    totalPrice: Number(getV(['ราคาขาย', 'ราคา'])) || 0,
                                    costPrice: Number(getV(['ต้นทุน'])) || 0,
                                    downPayment: Number(getV(['เงินดาวน์', 'ดาวน์'])) || 0,
                                    monthlyPay: Number(getV(['ค่างวด', 'งวดละ'])) || 0,
                                    installments: Number(getV(['งวดทั้งหมด', 'จำนวนงวด'])) || 12,
                                    paidTotal: Number(getV(['ชำระแล้ว'])) || 0,
                                    contractDate: contractDateISO,
                                    currentDueDate: contractDateISO,
                                    status: 'active',
                                    mdmLostMode: lostMode,
                                    mdmDeletion: deletionStatus,
                                    mdmABM: abmStatus,
                                    mdmIOSVersion: iosVersion,
                                    mdmLastConnection: String(lastConn),
                                    addedByUser: staffUser,
                                    importSource: 'excel'
                                };
                                await addDoc(collection(db, "contracts"), payload);
                                successCount++;
                                document.getElementById('importStatus').innerText = `สำเร็จ: ${successCount} / ทั้งหมด: ${rows.length} รายการ`;
                                if (successCount % 100 === 0) await new Promise(resolve => setTimeout(resolve, 500));
                            } catch (err) { console.error("แถวที่ " + (i+1) + " มีปัญหา:", err); errorCount++; }
                        }
                        statusDiv.style.borderLeftColor = "var(--success)";
                        statusDiv.innerHTML = `<b>นำเข้าสำเร็จ!</b><br>ทั้งหมด ${successCount} รายการ${errorCount > 0 ? `<br><small style="color:red">ผิดพลาด ${errorCount} รายการ</small>` : ""}`;
                        setTimeout(() => statusDiv.remove(), 5000);
                        renderAll();
                    }
                } catch (err) { alert("ไฟล์ Excel มีปัญหา โปรดตรวจสอบหัวตารางอีกครั้งครับ"); }
                e.target.value = "";
            };
            reader.readAsArrayBuffer(file);
        };
    }
    setupExcelUpload('excelUpload');
    setupExcelUpload('excelUploadLogin');
    // ===== นำเข้าตารางขาย format หน้ามอ (ทุก sheet = สาขา, เฉพาะ "ขายผ่อน") =====
    // Column map:
    // A[0]=วันที่, B[1]=เดือน, C[2]=ช่องทาง, D[3]=อาชีพ, E[4]=อายุ, F[5]=บัตรสี,
    // G[6]=ชื่อ-สกุล, H[7]=เบอร์, I[8]=จังหวัด, J[9]=พนง., K[10]=ประเภทขาย,
    // L[11]=สินค้า, M[12]=รุ่น, N[13]=SN, O[14]=สด, P[15]=โอน,
    // Q[16]=ดาวน์, R[17]=ผ่อน/ด., S[18]=ระยะเวลา, T[19]=รวม, U[20]=ต้นทุน
    document.getElementById('excelSalesUpload').onchange = async (e) => {
        const file = e.target.files[0]; if(!file) return;
        const reader = new FileReader();
        reader.onload = async (ev) => {
            try {
                const wb = XLSX.read(new Uint8Array(ev.target.result), {type:'array', cellDates:true, raw:false});
                const normSN = (s) => String(s||'').replace(/^SN\s*:?\s*/i,'').trim().toUpperCase();
                const normNum = (s) => parseFloat(String(s||'0').replace(/,/g,''))||0;
                const normInt = (s) => parseInt(String(s||'0').replace(/,/g,''))||0;
                const existingSNs = new Set(cachedContracts.map(c => normSN(c.sn)));
                // รวม row จากทุก sheet พร้อมระบุชื่อ sheet = branchId
                const allRows = [];
                for (const sheetName of wb.SheetNames) {
                    const ws = wb.Sheets[sheetName];
                    const rows = XLSX.utils.sheet_to_json(ws, { header:1, defval:'', raw:false });
                    rows.slice(1).forEach(r => allRows.push({ sheet: sheetName, row: r }));
                }
                // filter: ต้องเป็น "ขายผ่อน" + มีชื่อ + มี SN
                const isInstallment = (v) => {
                    const s = String(v||'').trim();
                    return s.includes('ผ่อน') || s.toLowerCase().includes('installment');
                };
                let toImport = [], toBackfill = [], skippedDup = [], skippedType = 0, skippedNoName = 0, skippedNoSN = 0;
                const typeBreakdown = {};
                // FIX: สร้าง map SN → contract เพื่อใช้ตรวจ backfill (อาชีพ/อายุ/ช่องทาง)
                const contractBySN = {};
                cachedContracts.forEach(c => { const k = normSN(c.sn); if (k) contractBySN[k] = c; });
                allRows.forEach(({ sheet, row }) => {
                    const name = String(row[6]||'').trim();
                    if (!name) { skippedNoName++; return; }
                    const saleType = String(row[10]||'').trim();
                    if (saleType) typeBreakdown[saleType] = (typeBreakdown[saleType]||0) + 1;
                    if (!isInstallment(saleType)) { skippedType++; return; }
                    const sn = normSN(row[13]);
                    if (!sn) { skippedNoSN++; return; }
                    if (existingSNs.has(sn)) {
                        // FIX: ถ้า SN มีอยู่แล้ว — เช็คว่ามี อาชีพ/อายุ/ช่องทาง รึยัง ถ้ายัง → backfill
                        const existing = contractBySN[sn];
                        const channel = String(row[2]||'').trim();
                        const occupation = String(row[3]||'').trim();
                        const age = String(row[4]||'').trim();
                        const needsBackfill = existing && (
                            (!existing.channel && channel) ||
                            (!existing.occupation && occupation) ||
                            (!existing.age && age)
                        );
                        if (needsBackfill) {
                            toBackfill.push({ id: existing.id, sn, name, channel, occupation, age });
                        } else {
                            skippedDup.push({sn, name});
                        }
                        return;
                    }
                    toImport.push({ sheet, row, sn, name });
                });
                // สรุปก่อน import
                const perBranchCount = {};
                toImport.forEach(it => { perBranchCount[it.sheet] = (perBranchCount[it.sheet]||0) + 1; });
                const branchLines = Object.entries(perBranchCount).map(([b,c]) => `  • ${b}: ${c} ราย`).join('\n') || '  (ไม่มี)';
                const typeLines = Object.entries(typeBreakdown).map(([t,c]) => `  • ${t}: ${c}`).join('\n');
                const msg =
                    `สรุปก่อนนำเข้า\n\n` +
                    `จะ import (ขายผ่อน เท่านั้น): ${toImport.length} ราย\n${branchLines}\n\n` +
                    (toBackfill.length > 0 ? `เติมข้อมูลเก่า (อาชีพ/อายุ/ช่องทาง): ${toBackfill.length} ราย\n` : '') +
                    `ข้าม (SN ซ้ำ - ข้อมูลครบแล้ว): ${skippedDup.length} ราย\n` +
                    `⏭  ข้าม (ไม่ใช่ขายผ่อน): ${skippedType} ราย\n` +
                    ` ข้าม (ไม่มีชื่อ): ${skippedNoName} ราย\n` +
                    ` ข้าม (ไม่มี SN): ${skippedNoSN} ราย\n` +
                    (typeLines ? `\nประเภทที่พบในไฟล์:\n${typeLines}\n` : '') +
                    `\nยืนยันนำเข้า ${toImport.length} + เติมข้อมูลเก่า ${toBackfill.length} รายการ?`;
                if (toImport.length === 0 && toBackfill.length === 0) {
                    alert(msg);
                    e.target.value=''; return;
                }
                if (!confirm(msg)) { e.target.value=''; return; }
                const statusDiv = document.createElement('div');
                statusDiv.style.cssText='position:fixed;top:20px;right:20px;background:white;padding:20px;border-radius:15px;box-shadow:0 10px 25px rgba(0,0,0,0.2);z-index:9999;border-left:5px solid #0EA5E9;min-width:260px;';
                statusDiv.innerHTML='<b>กำลังนำเข้า...</b><br><small id="salesImportStatus">รอสักครู่...</small>';
                document.body.appendChild(statusDiv);
                let done=0, err=0;
                for (const { sheet, row, sn, name } of toImport) {
                    try {
                        const channel    = String(row[2]||'').trim();
                        const occupation = String(row[3]||'').trim();
                        const age        = String(row[4]||'').trim();
                        const phone   = String(row[7]||'').trim();
                        const province= String(row[8]||'').trim();
                        const brand   = String(row[11]||'').trim().toLowerCase();
                        const model   = String(row[12]||'').trim();
                        const down    = normNum(row[16]);
                        const monthly = normNum(row[17]);
                        const install = normInt(row[18]) || 12;
                        const colP    = normNum(row[15]);   // โอน = ราคารวม
                        const cost    = normNum(row[20]);
                        // totalPrice: ใช้ colP (โอน) ถ้ามี, ไม่งั้นคำนวณจาก ดาวน์+ผ่อน×ระยะ
                        // (คอลัมน์ T ของ sheet เดิมเป็นกำไร ไม่ใช่ราคารวม จึงไม่ใช้)
                        const calcTotal = down + monthly * install;
                        const total = calcTotal > 0 ? calcTotal : (colP > 0 ? colP : 0);
                        let type = 'normal';
                        if (brand.includes('android') || brand.includes('samsung')) type = 'android';
                        // วันที่
                        let contractDate = new Date().toISOString();
                        const rawDate = row[0];
                        if (rawDate) {
                            const d = new Date(rawDate);
                            if (!isNaN(d)) contractDate = new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12).toISOString();
                        }
                        const dueDate = new Date(contractDate);
                        dueDate.setMonth(dueDate.getMonth()+1);
                        const payload = {
                            customerName: name, customerPhone: phone,
                            productName: model, sn,
                            totalPrice: total, costPrice: cost, downPayment: down,
                            monthlyPay: monthly, installments: install,
                            paidTotal: 0,
                            branchId: sheet,
                            province, // เก็บจังหวัดไว้ด้วย
                            channel, occupation, age, // FIX: เก็บข้อมูล demographic จาก Excel
                            contractDate, currentDueDate: dueDate.toISOString(),
                            dueDay: dueDate.getDate(), type, status: 'active'
                        };
                        const ref = await addDoc(collection(db,'contracts'), payload);
                        cachedContracts.push({ id: ref.id, ...payload });
                        existingSNs.add(sn);
                        done++;
                        const el = document.getElementById('salesImportStatus');
                        if (el) el.innerText = `นำเข้าแล้ว ${done}/${toImport.length}`;
                    } catch (ex) { console.error(ex); err++; }
                }
                // FIX: Backfill — เติมข้อมูล อาชีพ/อายุ/ช่องทาง ลงสัญญาเดิม (โดยไม่ทับ field อื่น)
                let backfillDone = 0, backfillErr = 0;
                for (const item of toBackfill) {
                    try {
                        const updateData = {};
                        if (item.channel) updateData.channel = item.channel;
                        if (item.occupation) updateData.occupation = item.occupation;
                        if (item.age) updateData.age = item.age;
                        if (Object.keys(updateData).length > 0) {
                            await updateDoc(doc(db, 'contracts', item.id), updateData);
                            // อัปเดต cache ใน memory
                            const idx = cachedContracts.findIndex(c => c.id === item.id);
                            if (idx >= 0) cachedContracts[idx] = { ...cachedContracts[idx], ...updateData };
                            backfillDone++;
                        }
                        const el = document.getElementById('salesImportStatus');
                        if (el) el.innerText = `เติมข้อมูลแล้ว ${backfillDone}/${toBackfill.length}`;
                    } catch (ex) { console.error('[backfill]', ex); backfillErr++; }
                }
                statusDiv.style.borderLeftColor='#22C55E';
                statusDiv.innerHTML = `<b>นำเข้าสำเร็จ!</b><br>เพิ่มใหม่ ${done} ราย · เติมข้อมูล ${backfillDone} ราย · ข้ามซ้ำ ${skippedDup.length} ราย` +
                    (err > 0 ? `<br><small style="color:red">ผิดพลาด ${err} ราย</small>` : '') +
                    (backfillErr > 0 ? `<br><small style="color:red">backfill error ${backfillErr} ราย</small>` : '');
                setTimeout(() => statusDiv.remove(), 6000);
                renderAll();
            } catch (ex) { alert('ไฟล์มีปัญหา: ' + ex.message); console.error(ex); }
            e.target.value='';
        };
        reader.readAsArrayBuffer(file);
    };
    window.exportExcel = () => {
