            try { dateStr = new Date(log.timestamp).toLocaleDateString('th-TH', {year:'numeric', month:'long', day:'numeric'}); } catch(e){}
            const hasId = !!log.id;
            if (isReversal) {
                // แถวรีไฟแนนซ์ — ขีดเส้นแดงทั้งแถว
                return `<div style="position:relative;padding:12px;border-radius:10px;margin-bottom:8px;background:#FFF5F5;border:2px solid #FCA5A5;overflow:hidden;">
