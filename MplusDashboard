            totalPrice:   Number(document.getElementById('qe_total').value) || 0,
            downPayment:  Number(document.getElementById('qe_down').value) || 0,
            monthlyPay:   Number(document.getElementById('qe_monthly').value) || 0,
            installments: Number(document.getElementById('qe_install').value) || 0,
            paidTotal:    Number(document.getElementById('qe_paid').value) || 0,
        };
        if (!payload.monthlyPay) {
            if(saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'บันทึก'; }
            alert('กรุณาใส่ค่างวดครับ'); return;
        }
        try {
            // คำนวณวันนัดชำระใหม่ตาม paidTotal ที่แก้ไข (ย้ายเข้า try-catch เพื่อ catch RangeError จาก Invalid Date)
            const contractQE = cachedContracts.find(c => c.id === id);
            if (contractQE) {
                const mPayQE = payload.monthlyPay || 1;
                const paidInstQE = Math.floor(payload.paidTotal / mPayQE);
                const rawDate = contractQE.contractDate ? new Date(contractQE.contractDate) : null;
                const contractDateQE = (rawDate && !isNaN(rawDate.getTime())) ? rawDate : new Date();
                const dueDayQE = contractQE.dueDay || (contractQE.currentDueDate ? new Date(contractQE.currentDueDate).getDate() : contractDateQE.getDate());
                const newDueQE = new Date(contractDateQE.getFullYear(), contractDateQE.getMonth() + paidInstQE + 1, 1);
                const maxDayQE = new Date(newDueQE.getFullYear(), newDueQE.getMonth() + 1, 0).getDate();
                newDueQE.setDate(Math.min(dueDayQE, maxDayQE));
                newDueQE.setHours(12, 0, 0, 0);
                if (!isNaN(newDueQE.getTime())) payload.currentDueDate = newDueQE.toISOString();
            }
            await updateDoc(doc(db, "contracts", id), payload);
            cachedContracts = cachedContracts.map(c => c.id === id ? { ...c, ...payload } : c);
