                el.innerHTML = '<div style="font-size:12px;color:#94A3B8;text-align:center;padding:10px;">ยังไม่มีกลุ่มที่เพิ่มเอง</div>';
                return;
            }
            el.innerHTML = window._customTypes.map(t => `
                <div style="padding:10px 12px;background:#F8FAFC;border-radius:8px;margin-bottom:6px;border:1px solid #E2E8F0;">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div>
                            <span style="font-size:13px;font-weight:600;color:#0F172A;">${t.label}</span>
                            <span style="font-size:11px;color:#94A3B8;margin-left:6px;">[${t.key}]</span>
                        </div>
                        <button onclick="window.deleteCustomType('${t.id}','${t.key}')" style="background:#FEF2F2;color:#DC2626;border:none;border-radius:6px;padding:4px 10px;font-family:Kanit;font-size:12px;cursor:pointer;">ลบ</button>
                    </div>
                    <label style="display:flex;align-items:center;gap:6px;font-size:11.5px;color:#475569;margin-top:8px;cursor:pointer;user-select:none;">
                        <input type="checkbox" ${t.standalone ? 'checked' : ''} onchange="window.toggleStandalone('${t.id}', this.checked)" style="cursor:pointer;accent-color:#1D4ED8;">
                        แยกออกจากระบบติดตาม + สรุปยอด (เช่น iPhone แลกเงิน)
                    </label>
                </div>`).join('');
        };

        // toggle flag "standalone" — เมื่อเปิด: ลูกค้ากลุ่มนี้จะไม่โผล่ใน follow-up tab / grade-color / KPI
        window.toggleStandalone = async (docId, value) => {
