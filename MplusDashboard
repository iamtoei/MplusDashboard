    window.doBulkFix = async () => {
        const fromVal = Number(document.getElementById('bulk_from').value);
        const toVal = Number(document.getElementById('bulk_to').value);
        const matches = cachedContracts.filter(c => Number(c.monthlyPay) === fromVal && c.status !== 'returned');
        if (matches.length === 0) { alert('ไม่พบสัญญาที่ตรงเงื่อนไข'); return; }
        if (!confirm(`ยืนยันอัปเดตค่างวด ${matches.length} สัญญา จาก ${fromVal}฿ → ${toVal.toLocaleString()}฿ ?`)) return;
        const btn = document.getElementById('bulkFixBtn');
        btn.disabled = true; btn.innerText = 'กำลังอัปเดต...';
        let done = 0;
        for (const c of matches) {
            try {
                await updateDoc(doc(db, "contracts", c.id), { monthlyPay: toVal });
                cachedContracts = cachedContracts.map(x => x.id === c.id ? { ...x, monthlyPay: toVal } : x);
                done++; btn.innerText = `กำลังอัปเดต ${done}/${matches.length}...`;
            } catch(e) { console.error(e); }
        }
        btn.disabled = false; btn.innerText = 'อัปเดตทั้งหมด';
        window.closeModal('bulkFixModal'); renderAll();
        alert(`อัปเดตสำเร็จ ${done} สัญญา`);
    };
