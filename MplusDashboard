            alert('บันทึกไม่สำเร็จ: ' + e.message);
        } finally {
            // reset ปุ่มเสมอ ไม่ว่าจะสำเร็จหรือไม่
            if(saveBtn) { saveBtn.disabled = false; saveBtn.textContent = 'บันทึก'; }
        }
    };
