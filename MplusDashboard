    window.setBranchSummaryPreset = function(key) {
        const pad = n => String(n).padStart(2,'0');
        const iso = d => d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate());
        const today = new Date(); today.setHours(0,0,0,0);
        let from = '', to = '';
        if (key === 'all') { from = ''; to = ''; }
        else if (key === 'today') { from = iso(today); to = iso(today); }
        else if (key === '7d') {
            const s = new Date(today); s.setDate(s.getDate()-6);
            from = iso(s); to = iso(today);
        }
        else if (key === '30d') {
            const s = new Date(today); s.setDate(s.getDate()-29);
            from = iso(s); to = iso(today);
        }
        else if (key === 'tm') {
            const s = new Date(today.getFullYear(), today.getMonth(), 1);
            const e = new Date(today.getFullYear(), today.getMonth()+1, 0);
            from = iso(s); to = iso(e);
        }
        else if (key === 'lm') {
            const s = new Date(today.getFullYear(), today.getMonth()-1, 1);
            const e = new Date(today.getFullYear(), today.getMonth(), 0);
            from = iso(s); to = iso(e);
        }
        else if (key === 'ty') {
            const s = new Date(today.getFullYear(), 0, 1);
            const e = new Date(today.getFullYear(), 11, 31);
            from = iso(s); to = iso(e);
        }
        if (!window._branchSummaryState) window._branchSummaryState = { branchKey:null, from:'', to:'', dateMode:'contract' };
        window._branchSummaryState.from = from;
        window._branchSummaryState.to = to;
        window._branchSummaryState._preset = key;
        window.openBranchSummary(undefined);
