        const el = document.getElementById('dovPlBranchList');
        if (!el) return;
        if (sorted.length === 0) { el.innerHTML = '<div style="text-align:center;color:#94A3B8;padding:24px;font-size:13px;">ไม่มีรายรับ</div>'; return; }
        el.innerHTML = sorted.map((b,i) => `<div class="dov-branch-row"><span class="dov-rank ${i===0?'top':''}">${i+1}</span><div class="dov-branch-name">${b[0]}</div><div class="dov-branch-bar"><span style="width:${(b[1]/max*100).toFixed(0)}%"></span></div><div class="dov-branch-amt">${fmt(b[1])}</div></div>`).join('');
    }

    function renderPlExpenseBranchList(exps) {
        const map = {};
        exps.forEach(e => { const b = e.branchId || 'ส่วนกลาง'; map[b] = (map[b]||0) + (Number(e.amount)||0); });
        const sorted = Object.entries(map).sort((a,b) => b[1]-a[1]).slice(0,5);
        const max = sorted[0] ? sorted[0][1] : 1;
        const el = document.getElementById('dovPlExpenseBranchList');
        if (!el) return;
        if (sorted.length === 0) { el.innerHTML = '<div style="text-align:center;color:#94A3B8;padding:24px;font-size:13px;">ไม่มีรายจ่าย</div>'; return; }
        el.innerHTML = sorted.map((b,i) => `<div class="dov-branch-row"><span class="dov-rank">${i+1}</span><div class="dov-branch-name">${b[0]}</div><div class="dov-branch-bar"><span style="width:${(b[1]/max*100).toFixed(0)}%; background:linear-gradient(90deg,#F87171,#DC2626);"></span></div><div class="dov-branch-amt">${fmt(b[1])}</div></div>`).join('');
    }

    function renderPlMarginChart(income, cost, expense, profit) {
        commonOpts();
        const ctx = document.getElementById('dovPlMarginChart');
        if (!ctx) return;
        destroyChart('plMargin');
        if (income === 0) {
            const cv = ctx.getContext('2d');
            cv.clearRect(0,0,ctx.width,ctx.height);
            cv.fillStyle = '#94A3B8'; cv.font = '13px Kanit'; cv.textAlign = 'center';
            cv.fillText('ยังไม่มีรายรับในเดือนนี้', ctx.width/2, ctx.height/2);
            return;
        }
        const profitPct = (profit / income * 100);
        _chartInstances.plMargin = new window.Chart(ctx, {
            type:'doughnut',
            data:{ labels:['ต้นทุน','รายจ่าย','กำไร'],
                datasets:[{ data:[cost, expense, Math.max(0, profit)], backgroundColor:['#F59E0B','#EF4444','#22C55E'], borderWidth:0, hoverOffset:5 }]
            },
            options:{ responsive:true, maintainAspectRatio:false, cutout:'72%',
                plugins:{
                    legend:{position:'bottom', labels:{usePointStyle:true, boxWidth:8, padding:10, font:{size:11}}},
                    tooltip:{ backgroundColor:'#0F172A', padding:10, cornerRadius:8, callbacks:{ label: c => c.label + ': ' + fmt(c.parsed) + ' (' + (c.parsed/income*100).toFixed(1) + '%)' } }
                }
            },
            plugins:[{
                id:'centerText',
                afterDraw(chart) {
                    const { ctx, chartArea: { left, right, top, bottom } } = chart;
                    const cx = (left + right) / 2;
                    const cy = (top + bottom) / 2;
                    ctx.save();
                    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                    ctx.font = 'bold 22px Kanit';
                    ctx.fillStyle = profit >= 0 ? '#15803D' : '#B91C1C';
                    ctx.fillText(profitPct.toFixed(1) + '%', cx, cy - 6);
                    ctx.font = '11px Kanit'; ctx.fillStyle = '#64748B';
                    ctx.fillText('Net Margin', cx, cy + 14);
                    ctx.restore();
                }
            }]
        });
    }

    function renderExpenseTable() {
        const body = document.getElementById('dovExpenseBody');
        const cnt = document.getElementById('dovExpenseCount');
        if (!body) return;
        const filtered = _expenses
            .filter(e => ymOf(e.date) === _plMonth && (!_plBranch || (e.branchId||'') === _plBranch))
            .sort((a,b) => (b.date||'').localeCompare(a.date||''));
        if (cnt) cnt.textContent = `${filtered.length.toLocaleString('th-TH')} รายการ — รวม ${fmt(filtered.reduce((s,e)=>s+(Number(e.amount)||0), 0))}`;
        if (filtered.length === 0) { body.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#94A3B8;padding:32px;">ยังไม่มีรายจ่ายในเดือนนี้ — กดปุ่ม "+ เพิ่มรายจ่าย" ด้านบนเพื่อบันทึก</td></tr>'; return; }
        body.innerHTML = filtered.map(e => {
            const cat = e.category || 'other';
            const dt = (() => { try { return new Date(e.date).toLocaleDateString('th-TH', {day:'2-digit', month:'short', year:'2-digit'}); } catch(_) { return e.date; } })();
            return `<tr>
                <td style="color:#475569;">${dt}</td>
                <td><span class="dov-pill" style="background:${CAT_COLOR[cat]}22;color:${CAT_COLOR[cat]};"><span class="dot" style="background:${CAT_COLOR[cat]};"></span>${CAT_LABEL[cat]||cat}</span></td>
                <td style="color:#475569;">${e.branchId || 'ส่วนกลาง'}</td>
                <td style="color:#475569;font-size:12.5px;">${(e.note||'').slice(0,40)}</td>
                <td style="text-align:right;font-weight:700;color:#B91C1C;">${fmt(e.amount)}</td>
                <td style="text-align:right;white-space:nowrap;">
                    <button onclick="window._dovOpenExpenseModal('${e.id}')" style="padding:5px 10px;border-radius:7px;border:1px solid #E2E8F0;background:white;cursor:pointer;font-family:Kanit;font-size:12px;color:#475569;">แก้</button>
                    <button onclick="window._dovDeleteExpense('${e.id}')" style="padding:5px 10px;border-radius:7px;border:none;background:#FEE2E2;color:#B91C1C;cursor:pointer;font-family:Kanit;font-size:12px;font-weight:600;">ลบ</button>
                </td>
            </tr>`;
        }).join('');
    }

})();
</script>

