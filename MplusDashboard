    function updateQEPreview() {
        const total = Number(document.getElementById('qe_total').value) || 0;
        const down = Number(document.getElementById('qe_down').value) || 0;
        const monthly = Number(document.getElementById('qe_monthly').value) || 0;
        const install = Number(document.getElementById('qe_install').value) || 0;
        const paid = Number(document.getElementById('qe_paid').value) || 0;
        if (!monthly || !total) return;
        const remain = Math.max(0, total - down - paid);
        const paidInst = monthly > 0 ? Math.floor(paid / monthly) : 0;
        const remainInst = install - paidInst;
        document.getElementById('qe_preview').style.display = 'block';
        document.getElementById('qe_preview_text').innerHTML = 
            `ยอดค้าง: <b>${remain.toLocaleString()} ฿</b><br>
            ชำระแล้ว: <b>${paidInst} งวด</b> / คงเหลือ: <b style="color:var(--danger)">${remainInst} งวด</b>`;
    }
