<script>
    /* ====== GAS REST API BRIDGE (Netlify → GAS fetch) ====== */
    // ★ ใส่ URL ของ GAS Deployment ที่นี่ (หลัง Deploy ใหม่ใน Apps Script)
    var GAS_API_URL = 'https://script.google.com/macros/s/AKfycbxGdUk1dM6NUq55x7l895BlOeR3q2GnsZncM5XMV2iYAA_i6sVMYQ4bT2GPZiHvo7fVgg/exec';

    function _gs(fn) {
        var args = Array.prototype.slice.call(arguments, 1);
        // args ที่เป็น object/array ให้ส่งเป็น JSON string เพื่อให้ GAS รับได้
        var mapped = args.map(function(a) {
            return (a !== null && a !== undefined && typeof a === 'object') ? JSON.stringify(a) : a;
        });
        var url = GAS_API_URL
            + '?fn=' + encodeURIComponent(fn)
            + '&args=' + encodeURIComponent(JSON.stringify(mapped));
        return fetch(url)
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(data) {
                if (data && data.error) throw new Error(data.error);
                // GAS dispatch wraps result — unwrap ถ้ามี
                return (data && data.result !== undefined) ? data.result : data;
            });
    }
    var db = {};
    function collection(dbRef, name) { return { _name: name }; }
    function doc(dbRef) { var args = Array.prototype.slice.call(arguments, 1); return { _coll: args[0], _id: args[1], _path: args }; }
    function getDocs(collRef) {
        return _gs('getAllData').then(function(data) {
            var coll = (collRef && collRef._name) || '';
            var arr = (data && data[coll]) || [];
            return {
                empty: arr.length === 0,
                docs: arr.map(function(d) { return { id: d.id, data: function() { return d; }, exists: true }; }),
                forEach: function(fn) { arr.forEach(function(d, i) { fn({ id: d.id, data: function() { return d; }, exists: true }, i); }); }
            };
        });
    }
    // ── recordPayment: 1 GAS call แทน 3 calls ──────────────────
    function recordPayment(contractId, fields, logs) {
        return _gs('recordPayment', contractId, fields, logs);
    }
    function addDoc(collRef, data) {
        var coll = (collRef && collRef._name) || '';
        if (coll === 'contracts') return _gs('saveContract', data).then(function(id){ return {id:id}; });
        if (coll === 'payment_logs') return _gs('addPaymentLog', data).then(function(id){ return {id:id}; });
        if (coll === 'tracking_logs') return _gs('addTrackingLog', data).then(function(id){ return {id:id}; });
        if (coll === 'grade_logs') return _gs('addGradeLog', data).then(function(id){ return {id:id}; });
        if (coll === 'expenses') return _gs('saveExpense', data).then(function(id){ return {id:id}; });
        if (coll === 'contract_types') return _gs('saveContractType', data).then(function(id){ return {id:id}; });
        if (coll === 'users') return _gs('saveUser', data).then(function(id){ return {id:id}; });
        return _gs('saveContract', data).then(function(id){ return {id:id}; });
    }
    function updateDoc(docRef, data) {
        var id = (docRef && docRef._id) || (docRef && docRef._path && docRef._path[1]);
        var coll = (docRef && docRef._coll) || (docRef && docRef._path && docRef._path[0]) || 'contracts';
        if (coll === 'contracts') return _gs('updateContractFields', id, data);
        if (coll === 'payment_logs') return _gs('addPaymentLog', Object.assign({}, data, {id:id}));
        if (coll === 'expenses') return _gs('saveExpense', Object.assign({}, data, {id:id}));
        if (coll === 'users') return _gs('saveUser', Object.assign({}, data, {id:id}));
        if (coll === 'contract_types') return _gs('saveContractType', Object.assign({}, data, {id:id}));
        if (coll === 'branches') return _gs('saveBranch', id, data);
        return _gs('updateContractFields', id, data);
    }
    function deleteDoc(docRef) {
        var id = (docRef && docRef._id) || (docRef && docRef._path && docRef._path[1]);
        var coll = (docRef && docRef._coll) || (docRef && docRef._path && docRef._path[0]) || 'contracts';
        if (coll === 'contracts') return _gs('deleteContract', id);
        if (coll === 'payment_logs') return _gs('deletePaymentLog', id);
        if (coll === 'tracking_logs') return _gs('deleteTrackingLog', id);
        if (coll === 'grade_logs') return _gs('deleteGradeLog', id);
        if (coll === 'expenses') return _gs('deleteExpense', id);
        if (coll === 'branches') return _gs('deleteBranch', id);
        if (coll === 'contract_types') return _gs('deleteContractType', id);
        if (coll === 'users') return _gs('deleteUser', id);
        return _gs('deleteContract', id);
    }
    function setDoc(docRef, data) {
        var coll = (docRef && docRef._coll) || (docRef && docRef._path && docRef._path[0]) || 'contracts';
        var id = (docRef && docRef._id) || (docRef && docRef._path && docRef._path[1]);
        if (coll === 'branches') return _gs('saveBranch', id, data);
        return updateDoc(docRef, data);
    }
    function getDoc(docRef) {
        return _gs('getAllData').then(function(allData) {
            var coll = (docRef && docRef._coll) || (docRef && docRef._path && docRef._path[0]) || 'contracts';
            var id = (docRef && docRef._id) || (docRef && docRef._path && docRef._path[1]);
            var arr = (allData && allData[coll]) || [];
            var found = arr.find(function(d) { return d.id === id; });
            return { exists: function() { return !!found; }, data: function() { return found; }, id: id };
        });
    }
    function getDocsFromServer(collRef) { return getDocs(collRef); }
    function onSnapshot(collRef, cb) { getDocs(collRef).then(cb).catch(function(){}); return function(){}; }
    function query(collRef) { return collRef; }
    function where() { return {}; }
    /* ====== END GAS BRIDGE ====== */
    
