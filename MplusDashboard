    window.openBranchSummary = function(branchKey) {
        const overlay = document.getElementById('branchSummaryOverlay');
        const body = document.getElementById('branchSummaryBody');
        const title = document.getElementById('branchSummaryTitle');
        if(!overlay || !body) return;
        // รับ/เก็บ state
        if (typeof branchKey !== 'undefined') window._branchSummaryState.branchKey = branchKey || null;
        const state = window._branchSummaryState;
        const fromInput = document.getElementById('branchSummaryFrom');
        const toInput = document.getElementById('branchSummaryTo');
        if (fromInput) fromInput.value = state.from || '';
        if (toInput) toInput.value = state.to || '';
        // date range (inclusive)
        const fromStr = state.from || '';
        const toStr = state.to || '';
        const fromMs = fromStr ? new Date(fromStr + 'T00:00:00').getTime() : null;
        const toMs = toStr ? new Date(toStr + 'T23:59:59').getTime() : null;
        const inRange = (c) => {
            if (!fromMs && !toMs) return true;
            const d = c.contractDate ? new Date(c.contractDate).getTime() : null;
            if (!d) return false;
            if (fromMs && d < fromMs) return false;
            if (toMs && d > toMs) return false;
            return true;
        };
        // โหมดวันที่: 'contract' = วันเซ็นสัญญา, 'payment' = วันเงินเข้า
        const dateMode = state.dateMode || 'contract';
        // ถ้าโหมด payment: สร้าง map ยอดชำระในช่วง (เฉพาะ type='installment') ต่อ contractId
        let paidByContract = null;
        if (dateMode === 'payment') {
            paidByContract = {};
            (window.cachedLogs || []).forEach(log => {
                if (!log.timestamp) return;
                if (log.type !== 'installment') return;
                const t = new Date(log.timestamp + 'T00:00:00').getTime();
                if (fromMs && t < fromMs) return;
                if (toMs && t > toMs) return;
                const cid = log.contractId;
                if (!cid) return;
                paidByContract[cid] = (paidByContract[cid] || 0) + (Number(log.amount) || 0);
            });
        }
        // ตัดสินใจว่าสัญญาไหนถูกรวมในรายงาน
        const includeContract = (dateMode === 'payment')
            ? (c) => ((paidByContract && paidByContract[c.id] > 0) || inRange(c))
            : inRange;
        // aggregate per branch (+ type breakdown per branch)
        const agg = {};
        const today = new Date(); today.setHours(0,0,0,0);
        const typeLabels = { normal:'ผ่อนปกติ', zero:'ผ่อน 0%', province:'ต่างจังหวัด', down999:'ดาวน์ 999', android:'Android' };
        const typeColors = { normal:'#6366F1', zero:'#22C55E', province:'#0EA5E9', down999:'#9333EA', android:'#10B981' };
        const ensure = (key, name) => {
            if(!agg[key]) agg[key] = { name:name||key||'ไม่ระบุสาขา', contracts:0, active:0, paidoff:0, returned:0, overdue:0, down:0, paid:0, debt:0, revenue:0, cost:0, profit:0, totalPrice:0, fullProfit:0, byType:{} };
            return agg[key];
        };
        (cachedContracts||[]).filter(includeContract).forEach(c => {
            const key = c.branchId || '__none__';
            const name = c.branchId || 'ไม่ระบุสาขา';
            const row = ensure(key, name);
            // ค่ารวมของสัญญาทั้งก้อน (ใช้เช็คสถานะ/ยอดค้าง)
            const cTotal = Number(c.totalPrice)||0;
            const cDown = Number(c.downPayment)||0;
            const cPaid = Number(c.paidTotal)||0;
            const cCost = Number(c.costPrice)||0;
            const remain = cTotal - cDown - cPaid;
            const signedInRange = inRange(c);
            // ค่าที่ใช้ aggregate (ปรับตามโหมด)
            const down = (dateMode === 'payment' && !signedInRange) ? 0 : cDown;
            const paid = (dateMode === 'payment')
                ? ((paidByContract && paidByContract[c.id]) || 0)
                : cPaid;
            const cost = (dateMode === 'payment' && !signedInRange) ? 0 : cCost;
            const total = (dateMode === 'payment' && !signedInRange) ? 0 : cTotal;
            const tp = c.type || c.contractType || 'normal';
            if(!row.byType[tp]) row.byType[tp] = { contracts:0, revenue:0, debt:0 };
            row.contracts++;
            row.down += down;
            row.paid += paid;
            row.cost += cost;
            row.totalPrice += total;
            row.revenue += (down + paid);
            row.byType[tp].contracts++;
            row.byType[tp].revenue += (down + paid);
            if(c.status === 'returned') row.returned++;
            else if(c.status === 'paidoff' || remain <= 0) row.paidoff++;
            else {
                row.active++;
                const rmax = Math.max(0, remain);
                row.debt += rmax;
                row.byType[tp].debt += rmax;
                const due = c.currentDueDate ? new Date(c.currentDueDate) : null;
                if(due) { due.setHours(0,0,0,0); const dd = Math.floor((today - due)/86400000); if(dd >= 4) row.overdue++; }
