        window.deleteDupContract = async (id, sn, customerName) => {
            if (!confirm('ยืนยันลบสัญญาของ "' + customerName + '" (SN: ' + sn + ')?\n\nข้อมูลจะหายถาวร ไม่สามารถกู้คืนได้')) return;
            try {
                // ลบ payment_logs ที่เกี่ยวข้อง
                const logsToDelete = cachedLogs.filter(l => l.contractId === id);
                await Promise.all(logsToDelete.map(l => deleteDoc(doc(db, 'payment_logs', l.id))));
                // ลบ contract
                await deleteDoc(doc(db, 'contracts', id));
                cachedContracts = cachedContracts.filter(c => c.id !== id);
                cachedLogs = cachedLogs.filter(l => l.contractId !== id);
                if (window._logsIndex) delete window._logsIndex[id];
                renderAll();
                window.renderDupSN();
                showTrackingToast('ลบแล้ว', customerName + ' · ' + sn);
