    function renderKPIs(all, ranged, active) {
        let cashIn = 0, debt = 0, dueSoon = 0;
        const customers = new Set();
        const now = new Date();
        const in7 = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 7);
        ranged.forEach(c => { cashIn += (Number(c.downPayment)||0) + (Number(c.paidTotal)||0); });
        active.forEach(c => {
            debt += Math.max(0, (Number(c.totalPrice)||0) - (Number(c.downPayment)||0) - (Number(c.paidTotal)||0));
            if (c.currentDueDate) {
                const d = new Date(c.currentDueDate);
                if (d >= now && d <= in7) dueSoon++;
            }
        });
        all.forEach(c => { if (c.customerName) customers.add(c.customerName.trim()); });
        const set = (id,v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
        set('dovKpiCash', fmt(cashIn));
        set('dovKpiActive', active.length.toLocaleString('th-TH'));
        set('dovKpiDebt', fmt(debt));
        set('dovKpiCust', customers.size.toLocaleString('th-TH'));
        set('dovKpiDue', dueSoon.toLocaleString('th-TH'));
        set('dovKpiCashFoot', `จาก ${ranged.length.toLocaleString('th-TH')} สัญญาในช่วงนี้`);
        set('dovKpiActiveFoot', `จาก ${all.length.toLocaleString('th-TH')} สัญญาทั้งหมด`);
    }

