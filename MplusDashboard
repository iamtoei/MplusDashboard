        const counts = { got_device:0, paid:0, not_found:0, follow_again:0 };
        data.forEach(t => { if(counts.hasOwnProperty(t.result)) counts[t.result]++; });
        const now = new Date().toLocaleDateString('th-TH', { year:'numeric', month:'long', day:'numeric' });
        const canvas = document.createElement('canvas');
        const scale = 2, W = 540;
        const gotList = data.filter(t => t.result === 'got_device');
        const paidList = data.filter(t => t.result === 'paid');
        const followList = data.filter(t => t.result !== 'got_device' && t.result !== 'paid');
        const estimatedH = 320 + (gotList.length * 60) + (paidList.length * 50) + (followList.length * 50) + 80;
        canvas.width = W * scale; canvas.height = estimatedH * scale;
        canvas.style.width = W + 'px'; canvas.style.height = estimatedH + 'px';
        const ctx = canvas.getContext('2d');
        ctx.scale(scale, scale);
        const rr = (x,y,w,h,r) => { ctx.beginPath(); ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r); ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h); ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r); ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y); ctx.closePath(); };
        const txt = (text, x, y, font, color, align='left') => { ctx.font = font; ctx.fillStyle = color; ctx.textAlign = align; ctx.fillText(text, x, y); ctx.textAlign = 'left'; };
        ctx.fillStyle = '#1A1F2C'; ctx.fillRect(0, 0, W, estimatedH);
        const grad = ctx.createLinearGradient(0,0,W,0); grad.addColorStop(0,'#1E40AF'); grad.addColorStop(1,'#1E3A8A');
        ctx.fillStyle = grad; rr(0,0,W,5,0); ctx.fill();
        txt('MPLUS SYSTEM', 24, 44, 'bold 22px Kanit, sans-serif', '#1E40AF');
        txt('สรุปผลการติดตาม — ' + (periodLabel[_currentTrackFilter]||''), 24, 72, '16px Kanit, sans-serif', '#FFFFFF');
        txt('' + now, 24, 96, '13px Kanit, sans-serif', '#94A3B8');
        ctx.strokeStyle = '#2D3548'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(24,110); ctx.lineTo(W-24,110); ctx.stroke();
        const cards = [
            { key:'got_device', label:'ได้เครื่อง', color:'#22C55E', bg:'#052E16', count: counts.got_device },
            { key:'paid', label:'จ่ายเงิน', color:'#1E3A8A', bg:'#431407', count: counts.paid },
            { key:'not_found', label:'ไม่เจอตัว', color:'#94A3B8', bg:'#1E293B', count: counts.not_found },
            { key:'follow_again', label:'ติดตามอีก', color:'#A78BFA', bg:'#2E1065', count: counts.follow_again },
        ];
        const cardW = (W - 48 - 18) / 4;
        cards.forEach((c, i) => { const x = 24 + i * (cardW + 6); ctx.fillStyle = c.bg; rr(x, 120, cardW, 72, 10); ctx.fill(); txt(String(c.count), x + cardW/2, 155, 'bold 26px Kanit, sans-serif', c.color, 'center'); txt(c.label, x + cardW/2, 175, '10px Kanit, sans-serif', c.color, 'center'); });
        let y = 212;
        const section = (title, color, items, lineColor) => {
            if(items.length === 0) return;
            ctx.fillStyle = color + '22'; rr(24, y, W-48, 30, 8); ctx.fill();
            ctx.fillStyle = color; ctx.font = 'bold 13px Kanit, sans-serif'; ctx.fillText(title + '  (' + items.length + ' ราย)', 38, y+20);
            y += 38;
            items.forEach((t) => {
                ctx.fillStyle = '#252B3B'; rr(24, y, W-48, 44, 8); ctx.fill();
                ctx.fillStyle = lineColor; rr(24, y, 4, 44, 2); ctx.fill();
                txt(t.customerName||'-', 38, y+17, 'bold 13px Kanit, sans-serif', '#FFFFFF');
                txt(t.productName||'-', 38, y+33, '11px Kanit, sans-serif', '#94A3B8');
                if(t.location && t.location !== '-') txt('' + t.location, W-28, y+17, '11px Kanit, sans-serif', '#64748B', 'right');
