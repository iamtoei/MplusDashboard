    document.getElementById('confirmRefinanceBtn').onclick = async () => {
        const modal = document.getElementById('refinanceModal');
        const id = modal.dataset.id;
        const installNum = Number(modal.dataset.installNum);
        const mPay = Number(modal.dataset.mPay);
        const refundAmt = Number(document.getElementById('rf_refundAmt').value) || 0;
        const startDateVal = document.getElementById('rf_startDate').value;
        if (!startDateVal) { alert('กรุณาเลือกวันที่เริ่มชำระงวดใหม่'); return; }
        if (refundAmt < 0) { alert('ยอดโอนคืนต้องไม่ติดลบ'); return; }
        const d = cachedContracts.find(c => c.id === id);
        if (!d) return;
        const startDateStr = new Date(startDateVal).toLocaleDateString('th-TH', {year:'numeric', month:'long', day:'numeric'});
        const note = `เริ่มชำระงวดที่ ${installNum} ใหม่ ในวันที่ ${startDateStr}` + (refundAmt > 0 ? ` (โอนคืนลูกค้า ${refundAmt.toLocaleString()} ฿)` : '');
        // คำนวณ paidTotal ใหม่ (หัก 1 งวด)
