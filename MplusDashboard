                cs.sort((a,b) => new Date(b.contractDate||0) - new Date(a.contractDate||0)).forEach((c, idx) => {
                    const pct = Math.round(((Number(c.paidTotal)||0) / Math.max(Number(c.totalPrice)||1,1)) * 100);
